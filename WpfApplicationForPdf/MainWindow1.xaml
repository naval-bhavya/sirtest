<Window x:Class="WpfApplicationForPdf.MainWindow1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow1" Height="870" Width="1099">
    <Grid>
        <TabControl BorderBrush="#FF727272" BorderThickness="1" FontFamily="Calibri" FontSize="14" Name="tabControl1" OverridesDefaultStyle="False" Padding="0" SnapsToDevicePixels="True" TabStripPlacement="Bottom" UseLayoutRounding="False" Background="#FFBEBEBE" >
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Control.Foreground" Value="Black" />
                    <Setter Property="Control.Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border BorderBrush="#FF727272" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Height="30" Margin="0,0" Name="Border">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" Margin="10,2" Name="ContentSite" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="TabItem.IsSelected" Value="True">
                                        <Setter Property="Border.Background" TargetName="Border" Value="#CC1BA1E2" />
                                    </Trigger>
                                    <Trigger Property="TabItem.IsSelected" Value="False">
                                        <Setter Property="Border.Background" TargetName="Border" Value="#AA9E9E9E" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabItem Header="PDF Viewer" Name="ViewPDF" Loaded="ViewPDF_Loaded">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26*" />
                        <RowDefinition Height="716*" />
                        <RowDefinition Height="28*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="27.919" />
                        <ColumnDefinition Width="187.459" />
                        <ColumnDefinition Width="29" />
                        <ColumnDefinition Width="794.619" />
                        <ColumnDefinition Width="36.893" />
                    </Grid.ColumnDefinitions>
                    <ListBox Grid.Column="1" Grid.Row="1" Name="listBoxPDF" SelectionChanged="listBoxPDF_SelectionChanged" />
                    <WebBrowser Grid.Column="3" Name="webBrowserPDF" Width="794.619" OpacityMask="#FFCBC8C8" Grid.ColumnSpan="2" Margin="2.622,-6,33.89,32" Grid.RowSpan="2" />
                    <Label Content="Please Generate Report" Grid.Column="1" Grid.Row="1" Height="28" HorizontalAlignment="Left" Margin="12.526,259.866,0,0" Name="lblListBoxError" VerticalAlignment="Top" Width="150.13" Foreground="Red" />
                    <Label Content="Please Select File from the List" Height="28" HorizontalAlignment="Left" Margin="327.622,259.867,0,0" Name="lblBrowserError" VerticalAlignment="Top" Width="182.13" Grid.Column="3" Grid.Row="1" Foreground="#FFD45A5A" />
                </Grid>
            </TabItem>
        </TabControl>
            <!--<WebBrowser Height="359" HorizontalAlignment="Left" Margin="260,23,0,0" Name="webBrowser1" VerticalAlignment="Top" Width="539" />-->
    </Grid>
</Window>
