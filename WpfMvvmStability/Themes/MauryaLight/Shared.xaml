<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<SolidColorBrush x:Key="AccentBrush" Color="#FF2FA4BD"/>
	<SolidColorBrush x:Key="PrimaryForeground" Color="#FF2C2828"/>
	<SolidColorBrush x:Key="SecondaryForeground" Color="Black"/>
	<SolidColorBrush x:Key="DisabledBrush" Color="#FFD1D1D1"/>
	<SolidColorBrush x:Key="SecondaryBackground" Color="#FFF1F5DE"/>
    <FontFamily x:Key="NormalFontFamily">Verdana</FontFamily>
	<SolidColorBrush x:Key="PrimaryBackground" Color="#FFD6D1D1"/>
    <SolidColorBrush x:Key="WindowBrush" Color="#FFB9B9B9"/>
    <SolidColorBrush x:Key="DisabledForeground" Color="Gray"/>
    <!-- Resource dictionary entries should be defined here. -->
</ResourceDictionary>