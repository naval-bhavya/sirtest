<Window x:Class="WpfMvvmStability.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Configuration Settings"
        Width="860"
        Height="620"
        MinWidth="780"
        MinHeight="560"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        Closed="Window_Closed">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" ShadowDepth="1" BlurRadius="18" Opacity="0.14" Color="#030032"/>

        <!-- Theme brushes are updated from code-behind so dark mode stays in sync -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F4F7FF"/>
        <SolidColorBrush x:Key="PageBgBrush" Color="#F4F7FF"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D8E2FF"/>
        <SolidColorBrush x:Key="DividerBrush" Color="#C4D0F8"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#526184"/>
        <SolidColorBrush x:Key="TextDisabledBrush" Color="#96A4C5"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1F48FF"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#4D6BFF"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#030032"/>
        <SolidColorBrush x:Key="PrimaryBgBrush" Color="#ECF1FF"/>
        <SolidColorBrush x:Key="PrimaryBorderBrush" Color="#9AB0FF"/>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#030032"/>
        <SolidColorBrush x:Key="ShellSurfaceBrush" Color="#0D125A"/>
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#233A96"/>
        <SolidColorBrush x:Key="ShellMutedBrush" Color="#A8B8EA"/>
        <SolidColorBrush x:Key="TextOnShellBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MenuPopupBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MenuPopupBorderBrush" Color="#D8E2FF"/>
        <SolidColorBrush x:Key="MenuPopupHoverBrush" Color="#EEF4FF"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputForegroundBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#1F48FF"/>
        <SolidColorBrush x:Key="TabIdleBrush" Color="#EAF0FF"/>
        <SolidColorBrush x:Key="TabHoverBrush" Color="#F7F9FF"/>
        <SolidColorBrush x:Key="TabSelectedBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TabBorderBrush" Color="#C7D4FF"/>
        <SolidColorBrush x:Key="NavIdleBackgroundBrush" Color="#1F48FF"/>
        <SolidColorBrush x:Key="NavIdleForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="NavIdleBorderBrush" Color="#6E8BFF"/>
        <SolidColorBrush x:Key="NavSelectedBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="NavSelectedForegroundBrush" Color="#030032"/>
        <SolidColorBrush x:Key="NavSelectedBorderBrush" Color="#1F48FF"/>
        <SolidColorBrush x:Key="ThemeActionBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeActionForegroundBrush" Color="#1F48FF"/>
        <SolidColorBrush x:Key="ThemeActionBorderBrush" Color="#9AB0FF"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#52C41A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF4D4F"/>
        <SolidColorBrush x:Key="DangerBgBrush" Color="#FFF1F0"/>

        <Style x:Key="DialogButtonBase" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MenuPopupHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavyButton" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Background" Value="{DynamicResource ShellBackgroundBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShellBackgroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ShellSurfaceBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Background" Value="{DynamicResource DangerBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer Focusable="False" Padding="0">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="10,6"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="ItemBorder"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PrimaryBgBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MenuPopupHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Background="{DynamicResource MenuPopupHoverBrush}"
                                        Padding="12,8"
                                        CornerRadius="8,8,0,0">
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      TextElement.FontSize="13"
                                                      TextElement.FontWeight="SemiBold"
                                                      TextElement.Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                                <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="TabBorder"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="ContentSite"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <Border x:Name="Indicator"
                                    Height="2"
                                    Background="Transparent"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Stretch"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource MenuPopupHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseDialogButton" TargetType="Button" BasedOn="{StaticResource DialogButtonBase}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Border x:Name="Backdrop"
                Background="#66030614"
                MouseLeftButtonDown="Backdrop_MouseLeftButtonDown">
            <Grid>
                <Border x:Name="DialogRoot"
                        Width="820"
                        MaxHeight="580"
                        Background="{DynamicResource CardBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MouseLeftButtonDown="DialogRoot_MouseLeftButtonDown"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                    </Border.RenderTransform>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource ShellBackgroundBrush}"
                                CornerRadius="12,12,0,0"
                                Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Configuration Settings"
                                               Foreground="{DynamicResource TextOnShellBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Backup, restore, and connection controls"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource ShellMutedBrush}"
                                               FontSize="11"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        x:Name="btnCloseHeader"
                                        Content="✕"
                                        Style="{StaticResource CloseDialogButton}"
                                        Click="btnClose_Click"
                                        VerticalAlignment="Top"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="14,12,14,10">
                            <TabControl x:Name="tabControl1"
                                        Background="Transparent"
                                        BorderThickness="0">
                                <TabControl.Template>
                                    <ControlTemplate TargetType="TabControl">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0"
                                                    BorderBrush="{DynamicResource DividerBrush}"
                                                    BorderThickness="0,0,0,2">
                                                <TabPanel IsItemsHost="True"
                                                          Background="Transparent"/>
                                            </Border>
                                            <Border Grid.Row="1" Padding="0,12,0,0">
                                                <ContentPresenter ContentSource="SelectedContent"/>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </TabControl.Template>

                                <TabItem Header="Backup / Restore" Name="tabItem1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <GroupBox Header="Server Settings" Name="groupBox1">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ListBox Grid.Column="0"
                                                                 Height="110"
                                                                 Name="listBoxSQLInstances"
                                                                 SelectionChanged="listBoxSQLInstances_SelectionChanged"/>
                                                        <ListBox Grid.Column="2"
                                                                 Height="110"
                                                                 Name="listBoxSqlDatabases"/>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="96"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" Content="Server Name" Height="30"/>
                                                        <TextBox Grid.Column="1" Name="textBoxServerName"/>
                                                        <Button Grid.Column="3"
                                                                Content="Connect"
                                                                Name="btnConnect"
                                                                Click="btnConnect_Click"
                                                                Style="{StaticResource PrimaryButton}"/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="55"/>
                                                            <ColumnDefinition Width="160"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="96"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" Content="User" Height="30"/>
                                                        <TextBox Grid.Column="1" Name="textBoxUser"/>
                                                        <Label Grid.Column="3" Content="Password" Height="30"/>
                                                        <TextBox Grid.Column="4" Name="textBoxPassword"/>
                                                        <Button Grid.Column="6"
                                                                Content="Create"
                                                                Name="btnCreate"
                                                                Click="btnCreate_Click"
                                                                Style="{StaticResource SecondaryButton}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </GroupBox>

                                            <GroupBox Header="Restore Database" Name="groupBox2">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="12"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="96"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" Content="File Path" Height="30"/>
                                                        <TextBox Grid.Column="1" Name="textBoxRestorePath"/>
                                                        <Button Grid.Column="3"
                                                                Content="Browse"
                                                                Name="btnBrowse"
                                                                Click="btnBrowse_Click"
                                                                Style="{StaticResource SecondaryButton}"/>
                                                    </Grid>
                                                    <Button Grid.Row="2"
                                                            Content="Restore"
                                                            Name="btnRestore"
                                                            Click="btnRestore_Click"
                                                            HorizontalAlignment="Right"
                                                            Style="{StaticResource PrimaryButton}"/>
                                                </Grid>
                                            </GroupBox>

                                            <GroupBox Header="Backup Database" Name="groupBox3">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="12"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="96"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" Content="File Path" Height="30"/>
                                                        <TextBox Grid.Column="1" Name="txtBoxBackupPath"/>
                                                        <Button Grid.Column="3"
                                                                Content="Browse"
                                                                Name="btnBrowse2"
                                                                Click="btnBrowse_Click"
                                                                Style="{StaticResource SecondaryButton}"/>
                                                    </Grid>
                                                    <Button Grid.Row="2"
                                                            Content="Backup"
                                                            Name="btnBackUp"
                                                            Click="btnRestore_Click"
                                                            HorizontalAlignment="Right"
                                                            Style="{StaticResource PrimaryButton}"/>
                                                </Grid>
                                            </GroupBox>

                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="Create Master Login"
                                                        Name="btnMasterLogin"
                                                        Click="btnMasterLogin_Click"
                                                        Style="{StaticResource SecondaryButton}"/>
                                                <Button Grid.Column="2"
                                                        Content="Close"
                                                        Name="btnClose"
                                                        Click="btnClose_Click"
                                                        Style="{StaticResource NavyButton}"/>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Connection Settings" Name="tabItem2">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <GroupBox Header="Modbus Communication">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                                        <Label Content="Type" Width="50" Height="30"/>
                                                        <RadioButton GroupName="ModbusType" Content="TCP" Name="radioButtonTCP"
                                                                     Margin="0,0,24,0"
                                                                     Checked="radioButtonTCP_Checked"
                                                                     VerticalAlignment="Center"/>
                                                        <RadioButton GroupName="ModbusType" Content="Serial" Name="radioButtonSerial"
                                                                     Checked="radioButtonSerial_Checked"
                                                                     VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="16"/>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Label Grid.Column="0" Content="COM Port" Height="30" Name="lblCOM"/>
                                                        <TextBox Grid.Column="1" Name="txtComPort"/>
                                                        <Label Grid.Column="3" Content="IP" Height="30" Name="lblIP"/>
                                                        <TextBox Grid.Column="4" Name="txtIP"/>
                                                    </Grid>
                                                </StackPanel>
                                            </GroupBox>

                                            <GroupBox Header="Server Name">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Label Grid.Column="0" Content="Server Name" Height="30" Name="label7"/>
                                                    <TextBox Grid.Column="1" Name="txtServerName"/>
                                                </Grid>
                                            </GroupBox>

                                            <GroupBox Header="Replication Settings" Name="groupBox4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.3*"/>
                                                        <ColumnDefinition Width="1.1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Label Grid.Column="0" Content="Computer Name" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <Label Grid.Column="1" Content="IP Address" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <Label Grid.Column="2" Content="Is Replication" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <Label Grid.Column="3" Content="Time Interval" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>

                                                    <TextBox Grid.Row="1" Grid.Column="0" Name="textBox4" Margin="2"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" Name="textBox3" Margin="2"/>
