                        <ComboBoxItem Content=" KL(II) " />
                    </ComboBox>
                    <MenuItem Header="Switch To Intact" Name="menuIntactDamage"  Background="#FFBEBEBE" VerticalAlignment="Top" Click="menuIntactDamage_Click" />
                </MenuItem>
                <MenuItem Header="_Help" FontFamily="Calibri" Background="#FFBEBEBE" Click="MenuItem_Click"  VerticalAlignment="Top">
                    <MenuItem Header="_User Manual" Name="UserManual"  Click="OpenUserManual_Click" Background="#FFBEBEBE"/>
                    <MenuItem Header="_About" Name="About" Click="About_Click" Background="#FFBEBEBE" VerticalAlignment="Top" />
                </MenuItem>


            </Menu.Items>
        </Menu>
        <DockPanel LastChildFill="True" Grid.Row="1" Background="#FFBEBEBE">
            <TabControl BorderBrush="#FF727272" BorderThickness="1" FontFamily="Calibri" FontSize="14" Name="tabControl1" OverridesDefaultStyle="False" Padding="0" SnapsToDevicePixels="True" TabStripPlacement="Bottom" UseLayoutRounding="False" Background="#FFBEBEBE" SelectionChanged="tabControl1_SelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Control.Foreground" Value="Black" />
                        <Setter Property="Control.Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border BorderBrush="#FF727272" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Height="30" Margin="0,0" Name="Border">
                                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" Margin="10,2" Name="ContentSite" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="TabItem.IsSelected" Value="True">
                                            <Setter Property="Border.Background" TargetName="Border" Value="#CC1BA1E2" />
                                        </Trigger>
                                        <Trigger Property="TabItem.IsSelected" Value="False">
                                            <Setter Property="Border.Background" TargetName="Border" Value="#AA9E9E9E" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabItem BorderBrush="#FF727272"  FontFamily="Calibri" FontSize="14" Header="Real Mode"  Name="tabItemReal" Width="200" Background="#FFBEBEBE" DataContext="{Binding}" GotFocus="tabItemReal_GotFocus">
                    <Grid IsItemsHost="False" ShowGridLines="False">
               
                        <StackPanel Grid.RowSpan="2">
                            <Frame  Template="{StaticResource templateRealMode}" Name="frameRealMode" ></Frame>
                        </StackPanel>
                        <DockPanel LastChildFill="True" Grid.Row="1">

                            <Label Content="Loading..." Name="tbProgress" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#80796969" />
                            
                        </DockPanel>
                       
                    </Grid>
                </TabItem>
                <TabItem BorderBrush="#CC1BA1E2"  FontFamily="Calibri" FontSize="14" Header="Simulation Mode" Name="tabItemSimulation" Width="200" GotFocus="tabItemSimulation_GotFocus">
                    <Grid IsItemsHost="False" ShowGridLines="False">
                        <StackPanel Grid.RowSpan="2">
                            <Frame Template="{StaticResource templateSimulationMode}" Name="frameSimulationMode" Navigated="frameSimulationMode_Navigated"></Frame>
                        </StackPanel> 
                    </Grid>
                </TabItem>
