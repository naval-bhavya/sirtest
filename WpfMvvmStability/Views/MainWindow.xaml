                        <ComboBoxItem Content=" E " />
                        <ComboBoxItem Content=" F " />
                        <ComboBoxItem Content=" G " />
                        <ComboBoxItem Content=" H " />
                        <ComboBoxItem Content=" I " />
                        <ComboBoxItem Content=" J " />
