<Window x:Class="WpfMvvmStability.Views.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:diagnostics="clr-namespace:System.Diagnostics;assembly=WindowsBase"
		xmlns:viewModels="clr-namespace:WpfMvvmStability.ViewModels"
        xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
        xmlns:modelViewer="clr-namespace:WpfMvvmStability.ViewModels"
        xmlns:modelView="clr-namespace:WpfMvvmStability.Views" 
   
    Title="" WindowStartupLocation="CenterScreen" Name="MainWin" 
    ResizeMode="CanMinimize" WindowStyle="SingleBorderWindow" Topmost="False" 
    xmlns:my="clr-namespace:WpfMvvmStability" 
    BorderThickness="0" SnapsToDevicePixels="True" FontFamily="Calibri"  
    WindowState="Normal" Loaded="Main_Loaded" Height="870" Width="1300" 
       
    Icon="/Stability;component/logo.ico" Background="#F0F2F5">

    <Window.Resources>

        <!-- ================= LIGHT BLUE THEME PALETTE ================= -->

        <!-- Primary -->
        <Color x:Key="PrimaryColor">#1890FF</Color>
        <Color x:Key="PrimaryLightColor">#40A9FF</Color>
        <Color x:Key="PrimaryDarkColor">#096DD9</Color>
        <Color x:Key="PrimaryBgColor">#E6F7FF</Color>
        <Color x:Key="PrimaryBorderColor">#91D5FF</Color>

        <!-- Neutral / Background -->
        <Color x:Key="PageBgColor">#F0F2F5</Color>
        <Color x:Key="CardBgColor">#FFFFFF</Color>
        <Color x:Key="BorderColor">#E0E0E0</Color>
        <Color x:Key="DividerColor">#D9D9D9</Color>

        <!-- Text -->
        <Color x:Key="TextPrimaryColor">#333333</Color>
        <Color x:Key="TextSecondaryColor">#555555</Color>
        <Color x:Key="TextDisabledColor">#999999</Color>

        <!-- Success / Danger / Warning -->
        <Color x:Key="SuccessColor">#52C41A</Color>
        <Color x:Key="DangerColor">#FF4D4F</Color>
        <Color x:Key="DangerBgColor">#FFF1F0</Color>
        <Color x:Key="WarningColor">#FA8C16</Color>
        <Color x:Key="WarningBgColor">#FFF7E6</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
        <SolidColorBrush x:Key="PrimaryBgBrush" Color="{StaticResource PrimaryBgColor}"/>
        <SolidColorBrush x:Key="PrimaryBorderBrush" Color="{StaticResource PrimaryBorderColor}"/>

        <SolidColorBrush x:Key="PageBgBrush" Color="{StaticResource PageBgColor}"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="DangerBgBrush" Color="{StaticResource DangerBgColor}"/>
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
        <SolidColorBrush x:Key="WarningBgBrush" Color="{StaticResource WarningBgColor}"/>

        <!-- ================= MODERN STYLES ================= -->

        <!-- 1. Button Styles -->
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" TargetName="Border" Value="{StaticResource PrimaryBgBrush}"/>
                                <Setter Property="BorderBrush" TargetName="Border" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource DangerBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 2. Label Styles -->
        <Style TargetType="Label" x:Key="StatusLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- 3. TabItem Style -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="{StaticResource BorderBrush}" 
                                BorderThickness="0" 
                                Margin="0,0,2,0" 
                                CornerRadius="4,4,0,0"
                                Height="35"
                                Width="200">
                            <ContentPresenter x:Name="ContentSite" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource DividerBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================= MODERN MENU STYLES ================= -->

        <!-- Top Level Menu Item Style (The Bar) -->
        <Style x:Key="MenuHeaderStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter x:Name="HeaderHost" ContentSource="Header" RecognizesAccessKey="True" 
                                                  Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsSubmenuOpen}" 
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                    <Border x:Name="SubmenuBorder" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                                            SnapsToDevicePixels="True" Effect="{DynamicResource DropShadow}">
                                        <ScrollViewer Margin="0,4" VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" TargetName="Border" Value="{StaticResource PrimaryBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter Property="Background" TargetName="Border" Value="{StaticResource PrimaryBgBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sub Menu Item Style (The Dropdown) -->
        <Style x:Key="SubMenuItemStyle" TargetType="MenuItem">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="20,8,10,8"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="Transparent">
                            <Grid>
                                <ContentPresenter x:Name="HeaderHost" ContentSource="Header" RecognizesAccessKey="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" TargetName="Border" Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================= TEMPLATES ================= -->

        <ControlTemplate TargetType="Frame" x:Key="templateRealMode">
            <DockPanel Background="#FAFBFF">
                <Border DockPanel.Dock="Top" Background="#030032" BorderThickness="0" Padding="12,8">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Left side buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">

                            <!-- Back Button -->
                            <Button Content="⬅ Back" Click="OnBackward" 
                        IsEnabled="{TemplateBinding CanGoBack}"
                        Width="120" Height="36" FontSize="13" FontWeight="SemiBold"
                        Foreground="#FFFFFF" Background="#1F48FF" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Stability Button -->
                            <Button Content="Stability" Click="OnGoPageRealStabilitySummary" 
                        Width="120" Height="36" Margin="10,0,5,0" FontSize="13" FontWeight="SemiBold"
                        Foreground="#030032" Background="#FFFFFF" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Stability Type Label -->
                            <Border Name="borderRealStabilityType" Background="#FFFFFF" CornerRadius="8" Margin="5,0" Width="120" Height="36"
                        BorderBrush="#1F48FF">
                                <Label Name="lblRealStabilityType" Content="NA" 
                           HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                           FontSize="12" FontWeight="Medium" Foreground="#030032"/>
                            </Border>

                            <!-- Stability Status Label -->
                            <Border Name="borderRealStabilityStatus" Background="#FFFFFF" CornerRadius="8" Margin="5,0" Width="120" Height="36"
                        BorderBrush="#1F48FF">
                                <Label Name="lblRealStabilityStatus" Content="NA" 
                           HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                           FontSize="12" FontWeight="Medium" Foreground="#030032"/>
                            </Border>

                            <!-- Corrective Action Button -->
                            <Button Content="Remedial Measures" Name="btnRealModeCorrectiveAction" 
                        Click="OnGoPageRealCorrectiveAction" Visibility="Hidden"
                        Width="120" Height="36" Margin="10,0,5,0" FontSize="12" FontWeight="SemiBold"
                        Foreground="#FFFFFF" Background="#1F48FF" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                        </StackPanel>

                        <!-- Right side buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                            <!-- Reports Button -->
                            <Button Content="Reports" Click="OnGoPageRealReport" 
                        Width="120" Height="36" Margin="5,0" FontSize="13" FontWeight="SemiBold"
                        Foreground="#FFFFFF" Background="#1F48FF" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Status Label --><!--
                            <Border Background="#FF4757" CornerRadius="8" Margin="10,0" Height="36" 
                        Width="120" VerticalAlignment="Center">
                                <Label Name="lblStatus" Content="COMMUNICATION" 
                           Foreground="#FFFFFF" FontSize="10" FontWeight="Bold"
                           HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                            </Border>-->

                            <!-- Switch to IPMS Button --><!--
                            <Button Name="btnExit" Content="Switch To IPMS" Click="btnExit_Click" 
                        Width="120" Height="36" FontSize="12" FontWeight="SemiBold"
                        Foreground="#FFFFFF" Background="#FF4757" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>-->

                        </StackPanel>
                    </Grid>
                </Border>
                <Border Background="#030032" Padding="5">
                    <ContentPresenter />
                </Border>
            </DockPanel>
        </ControlTemplate>

        <ControlTemplate TargetType="Frame" x:Key="templateSimulationMode">
            <DockPanel Background="#FAFBFF">
                <Border DockPanel.Dock="Top" Background="#030032" BorderThickness="0" Padding="12,8">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Left side buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">

                            <!-- Back Button -->
                            <Button Content="⬅ Back" Click="OnBackward" 
                            IsEnabled="{TemplateBinding CanGoBack}"
                            Width="120" Height="36" FontSize="13" FontWeight="SemiBold"
                            Foreground="#FFFFFF" Background="#1F48FF" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Stability Button -->
                            <Button Content="Stability" Name="btnSimulationModeStability" 
                            Click="OnGoPageSimulationStabilitySummary" IsEnabled="False"
                            Width="120" Height="36" Margin="10,0,5,0" FontSize="13" FontWeight="SemiBold"
                            Foreground="#030032" Background="#FFFFFF" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Stability Type Label -->
                            <Border Background="#FFFFFF" CornerRadius="8" Margin="5,0" Width="120" Height="36"
                            BorderBrush="#1F48FF" >
                                <Label Name="lblSimulationStabilityType" Content="NA" 
                               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                               FontSize="12" FontWeight="Bold" Foreground="#030032"/>
                            </Border>

                            <!-- Stability Status Label -->
                            <Border Background="#FFFFFF" CornerRadius="8" Margin="5,0" Width="120" Height="36"
                            BorderBrush="#1F48FF" >
                                <Label Name="lblSimulationStabilityStatus" Content="NA" 
                               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                               FontSize="12" FontWeight="Medium" Foreground="#030032"/>
                            </Border>

                            <!-- Corrective Action Button -->
                            <Button Content="Remedial Measures" Name="btnSimulationModeCorrectiveAction" 
                            Click="OnGoPageSimulationCorrectiveAction" IsEnabled="False"
                            Width="120" Height="36" Margin="10,0,5,0" FontSize="12" FontWeight="SemiBold"
                            Foreground="#FFFFFF" Background="#1F48FF" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                        </StackPanel>

                        <!-- Right side buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                            <!-- Reports Button -->
                            <Button Content="Reports" Name="btnSimulationGenerateReport" 
                            Click="btnSimulationGenerateReport_Click" IsEnabled="False"
                            Width="120" Height="36" Margin="5,0" FontSize="13" FontWeight="SemiBold"
                            Foreground="#FFFFFF" Background="#1F48FF" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>
                <Border Background="#030032" Padding="5">
                    <ContentPresenter />
                </Border>
            </DockPanel>
        </ControlTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <!-- MODERN MENU BAR -->
        <!-- Background White, Bottom Border for separation, ItemsPanel ensures proper layout -->
        <Menu Name="MainMenu" Background="#030032" Foreground="#FFFFFF" FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Top">
            <Menu.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </Menu.ItemsPanel>

            <Menu.Resources>
                <!-- Top-level menu header style -->
                <Style x:Key="ModernMenuHeader" TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="Padding" Value="14,8"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#1F48FF"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Submenu item style -->
                <Style x:Key="ModernSubMenuItem" TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#030032"/>
                    <Setter Property="Padding" Value="20,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="Regular"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#EEF1FF"/>
                            <Setter Property="Foreground" Value="#1F48FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Separator style -->
                <Style x:Key="ModernSeparator" TargetType="Separator">
                    <Setter Property="Background" Value="#E8E8E8"/>
                    <Setter Property="Margin" Value="10,4"/>
                    <Setter Property="Height" Value="1"/>
                </Style>
            </Menu.Resources>

            <!-- File -->
            <MenuItem Header="_File" Style="{StaticResource ModernMenuHeader}">
                <MenuItem Header="_Main Particulars" Name="Doc1" Click="Doc1_click" Style="{StaticResource ModernSubMenuItem}"/>
                <MenuItem Header="_General Arrangement" Name="Doc2" Click="Doc2_click" Style="{StaticResource ModernSubMenuItem}"/>
                <MenuItem Header="_Tank Capacity Plan" Name="Doc3" Click="Doc3_click" Style="{StaticResource ModernSubMenuItem}"/>
                <Separator Style="{StaticResource ModernSeparator}"/>
                <MenuItem Header="_Print Report" Name="Printreport" Click="Printreport_click" Style="{StaticResource ModernSubMenuItem}"/>
                <Separator Style="{StaticResource ModernSeparator}"/>
                <MenuItem Header="_Exit" Name="Exit4" Click="Exit_Click" Style="{StaticResource ModernSubMenuItem}"/>
            </MenuItem>

            <!-- View -->
            <MenuItem Header="_View" Style="{StaticResource ModernMenuHeader}">
                <MenuItem Header="_Saved Loading Condition" Name="SavedLoadingCondition" Style="{StaticResource ModernSubMenuItem}" Click="SavedLoadingCondition_Click"/>
                <MenuItem Header="_Pre-defined Loading Condition" Name="StandardLoadingCondition" Style="{StaticResource ModernSubMenuItem}" Click="StandardLoadingCondition_Click"/>
            </MenuItem>

            <MenuItem Header="_Configuration" Name="Configuration" Click="Configuration_Click" Style="{StaticResource ModernMenuHeader}"/>

            <!-- Master Input -->
            <MenuItem Header="_Vessel Data" Style="{StaticResource ModernMenuHeader}">
                <MenuItem Header="_LightShip Data" Name="LightShip" Style="{StaticResource ModernSubMenuItem}" Click="LightShip_Click"/>
                <MenuItem Header="_Stability Settings" Name="settings" Style="{StaticResource ModernSubMenuItem}" Click="settings_Click"/>
                <MenuItem Header="_Wind Speed" Name="windspeed" Style="{StaticResource ModernSubMenuItem}" Click="windspeed_Click"/>
            </MenuItem>

            <!-- Damage Cases -->
            <MenuItem Header="_Damage Cases" Name="MDamage" Style="{StaticResource ModernMenuHeader}">
                <Border Background="#FFFFFF" Padding="14" CornerRadius="8" BorderBrush="#E0E4EF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Select Damage Case" FontWeight="SemiBold" Margin="0,0,0,8" 
                           Foreground="#030032" FontSize="13" FontFamily="Segoe UI"/>

                        <Border BorderBrush="#1F48FF" BorderThickness="1.5" CornerRadius="6" Padding="0">
                            <ComboBox Name="cMBDamage" Width="240" SelectionChanged="cMBDamage_SelectionChanged" 
                              Height="34" FontFamily="Segoe UI" FontSize="13" BorderThickness="0"
                              Background="#FFFFFF" Foreground="#030032">
                                <ComboBoxItem Content="Select Damage Case" IsSelected="True"/>
                                <ComboBoxItem Content=" Damage case 1 "/>
                                <ComboBoxItem Content=" Damage case 2 "/>
                                <ComboBoxItem Content=" Damage case 3 "/>
                                <ComboBoxItem Content=" Damage case 4 "/>
                                <ComboBoxItem Content=" Damage case 5 "/>
                               
                            </ComboBox>
                        </Border>

                        <Button Content="Intact Condition" Name="menuIntactDamage" Margin="0,12,0,0" 
                        Height="34" Width="240" FontSize="13" FontWeight="SemiBold"
                        Foreground="#FFFFFF" Background="#1F48FF" BorderThickness="0" Cursor="Hand"
                        Click="menuIntactDamage_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </MenuItem>

            <!-- Help -->
            <MenuItem Header="_Help" Style="{StaticResource ModernMenuHeader}">
                <MenuItem Header="_User Manual" Name="UserManual" Click="OpenUserManual_Click" Style="{StaticResource ModernSubMenuItem}"/>
                <MenuItem Header="_About" Name="About" Click="About_Click" Style="{StaticResource ModernSubMenuItem}"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area -->
        <DockPanel LastChildFill="True" Grid.Row="1" Background="{StaticResource PageBgBrush}">
            <TabControl Name="tabControl1" BorderThickness="0" Background="Transparent" 
            VerticalContentAlignment="Stretch"
            TabStripPlacement="Bottom" SelectionChanged="tabControl1_SelectionChanged">

                <TabControl.Style>
                    <Style TargetType="TabControl">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ContentPresenter Grid.Row="0" 
                                              ContentSource="SelectedContent"/>
                                        <UniformGrid Grid.Row="1" Rows="1" 
                                         IsItemsHost="True"/>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Style>

                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="tabBorder" 
                                Background="#030032" 
                                BorderBrush="#1F48FF" 
                                BorderThickness="0" 
                                Padding="10,8" 
                                Cursor="Hand">
                                        <ContentPresenter ContentSource="Header" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="#FFFFFF"
                                              TextBlock.FontSize="14"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="tabBorder" Property="Background" Value="#1F48FF"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <!--<Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="tabBorder" Property="Background" Value="#162FA0"/>
                                        </Trigger>-->
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Real Mode Tab -->
                <TabItem Header="Sensor Streaming" Name="tabItemReal" GotFocus="tabItemReal_GotFocus">
                    <Grid Background="{StaticResource PrimaryBgBrush}" Margin="0,0,0,5">
                        <Frame Template="{StaticResource templateRealMode}" Name="frameRealMode" />
                        <Label Content="Loading..." Name="tbProgress" HorizontalContentAlignment="Center" 
                   VerticalContentAlignment="Center" 
                   Background="#80000000" Foreground="White" FontSize="16" Visibility="Collapsed"/>
                    </Grid>
                </TabItem>

                <!-- Simulation Mode Tab -->
                <TabItem Header="Virtual Simulation" Name="tabItemSimulation" GotFocus="tabItemSimulation_GotFocus">
                    <Grid Background="{StaticResource WarningBgBrush}" Margin="0,0,0,5">
                        <Frame Template="{StaticResource templateSimulationMode}" Name="frameSimulationMode" 
                   Navigated="frameSimulationMode_Navigated"/>
                    </Grid>
                </TabItem>

            </TabControl>

        </DockPanel>
    </Grid>

</Window>
