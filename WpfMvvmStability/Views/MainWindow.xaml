<Window x:Class="WpfMvvmStability.Views.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:diagnostics="clr-namespace:System.Diagnostics;assembly=WindowsBase"
		xmlns:viewModels="clr-namespace:WpfMvvmStability.ViewModels"
        xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
        xmlns:modelViewer="clr-namespace:WpfMvvmStability.ViewModels"
        xmlns:modelView="clr-namespace:WpfMvvmStability.Views" 
   
    Title="P15B" WindowStartupLocation="CenterScreen" Name="MainWin" ResizeMode="CanMinimize" WindowStyle="SingleBorderWindow" Topmost="False" xmlns:my="clr-namespace:WpfMvvmStability" HorizontalContentAlignment="Left" VerticalContentAlignment="Top" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Top="Auto" Left="Auto" BorderThickness="0" SnapsToDevicePixels="False" FontFamily="Calibri"  WindowState="Normal" Loaded="Main_Loaded" Height="870" Width="1099.89" Icon="/Stability;component/Lnt2.ico">
    <Window.Resources>
        
        <ControlTemplate TargetType="Frame" x:Key="templateRealMode">
            <DockPanel>
               <ToolBar DockPanel.Dock="Top" >
                    <DockPanel Margin="1">
                        <StackPanel
                    Margin="1"
                    Orientation="Horizontal"
                    DockPanel.Dock="Top">
                            <Button
                    Content="Back"
                    Click="OnBackward"
                                FontSize="14"
                    Width="50" Height="30"
                    IsEnabled="{TemplateBinding CanGoBack}" />
                   
                            <Button Content="Stability"  FontSize="14" VerticalContentAlignment="Center"  Margin="40,0,10,0" BorderThickness="1" Click="OnGoPageRealStabilitySummary" Width="80" Height="30"  />
                            <Label BorderBrush="#FF727272" Margin="10,0,10,0" BorderThickness="1" Content="NA" FontSize="14"  HorizontalContentAlignment="Center" Name="lblRealStabilityType" />
                            <Label BorderBrush="#FF727272" Margin="10,0,10,0" BorderThickness="1" Content="NA" FontSize="14" HorizontalContentAlignment="Center" x:Name="lblRealStabilityStatus"/>
                           
                           

                            <Button BorderBrush="#FF727272" Margin="10,0,10,0" Content="Corrective Action" FontFamily="Calibri" FontSize="14" Name="btnRealModeCorrectiveAction" Visibility="Hidden"  SnapsToDevicePixels="False" Click="OnGoPageRealCorrectiveAction"  />
                            <Button Click="OnGoPageRealReport" Margin="10,0,10,0" BorderThickness="1" Width="80" Height="30"  FontSize="14" Content="Reports" />
                            <Label   BorderThickness="0" Content="                                      " Name="lblConnectionstatus"  />
                            <Label BorderBrush="#FF727272"  Margin="1,0,10,0" Background="Red"  BorderThickness="1" Content="COMMUNICATION" FontSize="14" HorizontalContentAlignment="Center" Name="lblStatus"  />
                            <Button BorderBrush="#FF727272" Margin="100,0,10,0" Click="btnExit_Click" Content="Switch To IPMS" FontFamily="Calibri" FontSize="14" Name="btnExit" Grid.Row="1" Grid.RowSpan="1" Grid.Column="13" />
                           
                            
                        </StackPanel>
                    </DockPanel>
                </ToolBar>
                <Border
                        BorderBrush="Blue"
                        Margin="1"
                        BorderThickness="4"
                        Padding="1"
                        CornerRadius="4">
                    <ContentPresenter DockPanel.Dock="Bottom" />
                </Border>
                
            </DockPanel>
        </ControlTemplate>
        <ControlTemplate TargetType="Frame" x:Key="templateSimulationMode">
            <DockPanel>
                <ToolBar DockPanel.Dock="Top" >
                    <DockPanel Margin="1">
                        <StackPanel
                    Margin="1"
                    Orientation="Horizontal"
                    DockPanel.Dock="Top">
                            <Button
                    Content="Back"
                    Click="OnBackward"
                                FontSize="14"
                    Width="80" Height="30"
                    IsEnabled="{TemplateBinding CanGoBack}" />
                  
                            <Button Content="Stability" IsEnabled="False" Name="btnSimulationModeStability" FontSize="14" Margin="40,0,10,0" BorderThickness="1" Click="OnGoPageSimulationStabilitySummary" Width="80" Height="30"  />
                            <Label BorderBrush="#FF727272" Margin="10,0,10,0" BorderThickness="1" Content="NA" FontSize="14" FontWeight="Bold" HorizontalContentAlignment="Center" Name="lblSimulationStabilityType" />
                            <Label BorderBrush="#FF727272" Margin="10,0,10,0" BorderThickness="1" Content="NA" FontSize="14" HorizontalContentAlignment="Center" Name="lblSimulationStabilityStatus" />
                            <Button BorderBrush="#FF727272" Margin="10,0,10,0" Content="Corrective Action" FontFamily="Calibri" FontSize="14" Name="btnSimulationModeCorrectiveAction" SnapsToDevicePixels="False" Click="OnGoPageSimulationCorrectiveAction" IsEnabled="False"  />
                            <!--<Button BorderBrush="#FF727272" Margin="10,0,10,0" Content="Calculate" FontFamily="Calibri" FontSize="11" Height="25"  Name="btnSimulationCalculate" SnapsToDevicePixels="False" Click="btnSimulationCalculate_Click" />-->
                            <Button BorderBrush="#FF727272" Margin="40,0,10,0" Content="Reports" FontFamily="Calibri" FontSize="14" Height="30"   Width="90"  Name="btnSimulationGenerateReport" SnapsToDevicePixels="False" Click="btnSimulationGenerateReport_Click" IsEnabled="False"  />
                            <Label BorderBrush="#FF727272"  Margin="10,0,10,0" BorderThickness="1" Content="OFFLINE MODE"  Background="White" Foreground="Red" FontSize="14" HorizontalContentAlignment="Center" Name="lblconnectionstatus"  />
                            <!--<Button BorderBrush="#FF727272" Margin="10,0,10,0" Content="Save" FontFamily="Calibri" FontSize="11" Height="25"  Name="btnSaveLoadingCondition" SnapsToDevicePixels="False" Click="btnSaveLoadingCondition_Click" />-->
                            <Button BorderBrush="#FF727272" Margin="100,0,10,0" Click="btnExitSimulation_Click" Content="Switch To IPMS" FontFamily="Calibri" FontSize="14" Height="30" Name="btnExitSimulation"  HorizontalAlignment="Left" />
                        </StackPanel>
                    </DockPanel>
                </ToolBar>
                <Border Name="SimulationBorder"
                        BorderBrush="Red"
                        Margin="1"
                        BorderThickness="4"
                        Padding="1"
                        CornerRadius="7">
                    <ContentPresenter DockPanel.Dock="Bottom" />
                </Border>

            </DockPanel>
        </ControlTemplate>

    </Window.Resources>

    <Grid>
            <Grid.RowDefinitions>
            <RowDefinition Height="27" />
            <RowDefinition Height="835*" />
        </Grid.RowDefinitions>
        
        <Menu Name="MainMenu" BorderBrush="Black" DockPanel.Dock="Top" Background="#FFBEBEBE">
            <Menu.Items>
                <MenuItem Header="_File" Background="#FFBEBEBE" FontFamily="Calibri">
                    <!--<MenuItem Header="_Real Mode" Name="RM" Click="RM_Click" Background="#FFBEBEBE"></MenuItem>
                    <MenuItem Header="_Simulation Mode" Name="SM" Click="SM_Click" Background="#FFBEBEBE"></MenuItem>-->
                    <MenuItem Header="_Main Particulars" Name="Doc1"  Click="Doc1_click" Background="#FFBEBEBE"></MenuItem>
                    <MenuItem Header="_General Arrangement" Name="Doc2"  Click="Doc2_click" Background="#FFBEBEBE"></MenuItem>
                    <MenuItem Header="_Tank Capacity Plan" Name="Doc3" Click="Doc3_click" Background="#FFBEBEBE"></MenuItem>
                    <MenuItem Header="_Print Report" Name="Printreport"  Click="Printreport_click" Background="#FFBEBEBE"></MenuItem>
                    <MenuItem Header="_Exit" Name="Exit4" Click="Exit_Click" Background="#FFBEBEBE"></MenuItem>
                </MenuItem>
                <MenuItem Header="_View" Background="#FFBEBEBE" FontFamily="Calibri">
                    <MenuItem Header="_Saved Loading Condition" Name="SavedLoadingCondition" Background="#FFBEBEBE" Click="SavedLoadingCondition_Click"></MenuItem>
                    <MenuItem Header="_Pre-defined Loading Condition" Name="StandardLoadingCondition"  Background="#FFBEBEBE" Click="StandardLoadingCondition_Click"></MenuItem>
                </MenuItem>
                <MenuItem Header="_Tools" Background="#FFBEBEBE" FontFamily="Calibri">
                    <MenuItem Header="_Configuration" Name="Configuration" Click="Configuration_Click" Background="#FFBEBEBE"/>
                    <!--<MenuItem Header="_Set IPMS Path" Name="setipmspath" Click="setipmspath_Click" Background="#FFBEBEBE"/>-->
                </MenuItem>
                <MenuItem Header="_Master Input"   FontFamily="Calibri" Background="#FFBEBEBE" Click="MenuItem_Click" VerticalAlignment="Top" VerticalContentAlignment="Center">
                    <MenuItem Header="_LightShip Data" Name="LightShip"   Background="#FFBEBEBE" Click="LightShip_Click" />
                    <MenuItem Header="_Stability Settings" Name="settings"   Background="#FFBEBEBE" Click="settings_Click" />
                    <MenuItem Header="_Wind Speed" Name="windspeed"   Background="#FFBEBEBE" Click="windspeed_Click" />
                   

                </MenuItem>
                <MenuItem Header="_Damage Cases" Name="MDamage" FontFamily="Calibri" Background="#FFBEBEBE"  VerticalAlignment="Top" FontSize="14">
                    <ComboBox Name="cMBDamage" Width="145" SelectionChanged="cMBDamage_SelectionChanged" >
                        <ComboBoxItem Content="Select Damage Case"  IsSelected="True"/>
                        <ComboBoxItem Content=" GHIJ(ii) "/>
                        <ComboBoxItem Content=" KLMN(ii) " />
                        <ComboBoxItem Content=" LMNOP(ii) " />
