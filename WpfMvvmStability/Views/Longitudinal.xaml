<Page x:Class="WpfMvvmStability.Views.Longitudinal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:DV="clr-namespace:System.Windows.Controls.DataVisualization;assembly=System.Windows.Controls.DataVisualization.Toolkit"
             xmlns:DVC="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=System.Windows.Controls.DataVisualization.Toolkit"
      xmlns:chartPrimitive="clr-namespace:System.Windows.Controls.DataVisualization.Charting.Primitives;assembly=System.Windows.Controls.DataVisualization.Toolkit"       
      mc:Ignorable="d" Background="#FFBEBEBE" Height="770" Width="1079">
    <Page.Resources>
        <Style x:Key="ChartStyle1" TargetType="{x:Type DVC:Chart}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DVC:Chart}">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0"/>
                                    <RowDefinition Height="300"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0"/>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="650"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Content="{TemplateBinding Title}" FontFamily="Calibri" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <Grid Margin="0,15" Grid.Row="0"  Grid.Column="1" Grid.ColumnSpan="2" Grid.RowSpan="2">
                                    <chartPrimitive:EdgePanel x:Name="ChartArea" Style="{TemplateBinding ChartAreaStyle}">
                                        <Grid Style="{TemplateBinding PlotAreaStyle}" Panel.ZIndex="-1"/>
                                        <Border BorderBrush="#FF919191" BorderThickness="1" Panel.ZIndex="10"/>
                                    </chartPrimitive:EdgePanel>
                                </Grid>
                                <ContentControl x:Name="Legend" Grid.Row="2" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top" Content="{TemplateBinding LegendTitle}" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="Black"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="365*" />
            <ColumnDefinition Width="714*" />
        </Grid.ColumnDefinitions>
        <GroupBox Header="Strength Data" Height="267" HorizontalAlignment="Left" Margin="41,12,0,0" Name="groupBox1" VerticalAlignment="Top" Width="262" Background="#FF727272" BorderBrush="#FF727272" Grid.Column="1">
            <Grid>
                <DataGrid AutoGenerateColumns="False" Name="dgLongitudinal" CanUserReorderColumns="False" CanUserResizeColumns="False" CanUserResizeRows="False" CanUserSortColumns="False" GridLinesVisibility="Horizontal" IsReadOnly="True"  Margin="6" RowHeight="20" MinRowHeight="20">
                    <DataGrid.Columns>
                        <DataGridTextColumn MinWidth="50" Width="Auto" Header="Length" Binding="{Binding Length,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn MinWidth="70" Width="Auto" Header="Shear Force (T)" Binding="{Binding SF,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!--<DataGridTextColumn MinWidth="70" Width="Auto" Header="SF Permissible(T)" Binding="{Binding SF_Permissible,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn MinWidth="60" Width="Auto" Header="% SF" Binding="{Binding SF_Percentage_Diff,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>-->
                        <DataGridTextColumn MinWidth="80" Width="Auto" Header="BM (T-m)" Binding="{Binding BM,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <!--<DataGridTextColumn MinWidth="70" Width="Auto" Header="BM Permissible(T-m)" Binding="{Binding BM_Permissible,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn MinWidth="60" Width="Auto" Header="% BM" Binding="{Binding BM_Percentage_Diff,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>-->
                        <!--<DataGridTextColumn MinWidth="50" Width="Auto" Header="Buoyancy" Binding="{Binding BuoyanceUDL,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn MinWidth="50" Width="Auto" Header="NetLoad" Binding="{Binding NetUDL,StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>-->
                    </DataGrid.Columns>
                    <DataGrid.RowBackground>#FFD8D8D8</DataGrid.RowBackground>
                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FF727272"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Resources>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Style.Triggers>
                                <Trigger Property="DataGridCell.IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FF727272" />
                                    <Setter Property="BorderBrush" Value="#FF727272"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                </DataGrid>
            </Grid>
        </GroupBox>
        <GroupBox Header="Strength Graph" HorizontalAlignment="Left" Margin="44,285,0,59" Name="groupBox2" Width="1009" Background="#FF727272" BorderBrush="#FF727272" Grid.ColumnSpan="2">
            <Grid x:Name="gridLongitudinal">
                <DVC:Chart Canvas.Top="80" Canvas.Left="10"  Style="{DynamicResource ChartStyle1}" Name="LongitudinalChart" Background="#FFBEBEBE" Padding="5" FontFamily="Calibri" VerticalContentAlignment="Top" Margin="0,2,0,-67"> 
                    <DVC:Chart.Series>
                        <DVC:LineSeries Name="SFSeries" Title="Shear Force"
                                IndependentValueBinding="{Binding Path=Key}"
                                DependentValueBinding="{Binding Path=Value}"  ItemsSource="{Binding}" IsSelectionEnabled="True">
                            <DVC:LineSeries.DataPointStyle>
                                <Style TargetType="{x:Type DVC:LineDataPoint}">
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <Setter Property="Background" Value="LightBlue"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DVC:LineDataPoint">
                                                <Canvas x:Name="PlotArea"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DVC:LineSeries.DataPointStyle>
                            <DVC:LineSeries.DependentRangeAxis>
                                <DVC:LinearAxis x:Name="SF" Orientation="Y" 
                                    Title="Shear Force" 
                                         ShowGridLines="True">
 
                                </DVC:LinearAxis>
                            </DVC:LineSeries.DependentRangeAxis>
                        </DVC:LineSeries>
                       
                        <DVC:LineSeries Name="BMSeries" Title="Bending Moment"
                                IndependentValueBinding="{Binding Path=Key}"
                                DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True">
                            <DVC:LineSeries.DataPointStyle>
                                <Style TargetType="{x:Type DVC:LineDataPoint}">
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <Setter Property="Background" Value="LightGreen"/>
                                     <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DVC:LineDataPoint">
                                                <Canvas x:Name="PlotArea"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DVC:LineSeries.DataPointStyle>
                            
                            <DVC:LineSeries.LegendItemStyle>
                                <Style TargetType="{x:Type DVC:LegendItem}" >
                                    <Setter Property="Visibility" Value="Visible"></Setter>
                                </Style>
                            </DVC:LineSeries.LegendItemStyle>
                            <DVC:LineSeries.DependentRangeAxis>
                                <DVC:LinearAxis x:Name="BM"  Orientation="Y" 
                                    Title="Bending Moment" 
                                        ShowGridLines="False" ></DVC:LinearAxis>
                            </DVC:LineSeries.DependentRangeAxis>
                        </DVC:LineSeries>
                        <DVC:LineSeries Name="SFPermissibleHighSeries" Title="SF Permissible"
                                IndependentValueBinding="{Binding Path=Key}"
                                DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True" Visibility="Visible">
                            <DVC:LineSeries.DataPointStyle>
                                <Style TargetType="{x:Type DVC:LineDataPoint}">
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <Setter Property="Background" Value="Green"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DVC:LineDataPoint">
                                                <Canvas x:Name="PlotArea"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DVC:LineSeries.DataPointStyle>

                            <DVC:LineSeries.LegendItemStyle>
                                <Style TargetType="{x:Type DVC:LegendItem}" >
                                    <Setter Property="Visibility" Value="Visible"></Setter>
                                </Style>
                            </DVC:LineSeries.LegendItemStyle>
                            <DVC:LineSeries.DependentRangeAxis>
                                <DVC:LinearAxis x:Name="SFPermHigh" Orientation="Y" 
                                    Title="Shear Force" 
                                         ShowGridLines="False" Visibility="Hidden">

                                </DVC:LinearAxis>
                            </DVC:LineSeries.DependentRangeAxis>

                        </DVC:LineSeries>
                        <DVC:LineSeries Name="BMPermissibleHighSeries"
                                IndependentValueBinding="{Binding Path=Key}" Title="BM Permissible"
                                DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True" Visibility="Visible">
                            <DVC:LineSeries.DataPointStyle>
                                <Style TargetType="{x:Type DVC:LineDataPoint}">
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <!--<Setter Property="Background" Value="#8DB2776E"/>-->
                                    <Setter Property="Background" Value="Orange"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DVC:LineDataPoint">
                                                <Canvas x:Name="PlotArea"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DVC:LineSeries.DataPointStyle>

                            <DVC:LineSeries.LegendItemStyle>
                                <Style TargetType="{x:Type DVC:LegendItem}" >
                                    <Setter Property="Visibility" Value="Visible"></Setter>
                                </Style>
                            </DVC:LineSeries.LegendItemStyle>
                            <DVC:LineSeries.DependentRangeAxis>
                                <DVC:LinearAxis x:Name="BMPermHigh" Orientation="Y" 
                                    Title="Shear Force" 
                                         ShowGridLines="False" Visibility="Hidden">

                                </DVC:LinearAxis>
                            </DVC:LineSeries.DependentRangeAxis>
                        </DVC:LineSeries>
                       
                        <DVC:LineSeries Name="BMPermissibleLowSeries"
                                IndependentValueBinding="{Binding Path=Key}"
                                DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True" Visibility="Visible">
                            <DVC:LineSeries.DataPointStyle>
                                <Style TargetType="{x:Type DVC:LineDataPoint}">
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <Setter Property="Background" Value="#8DB2776E"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DVC:LineDataPoint">
                                                <Canvas x:Name="PlotArea"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DVC:LineSeries.DataPointStyle>

                            <DVC:LineSeries.LegendItemStyle>
                                <Style TargetType="{x:Type DVC:LegendItem}" >
                                    <Setter Property="Visibility" Value="Hidden"></Setter>
                                </Style>
                            </DVC:LineSeries.LegendItemStyle>
                            <DVC:LineSeries.DependentRangeAxis>
                                <DVC:LinearAxis x:Name="BMPermLow" Orientation="Y" 
                                    Title="Bending Moment Permissible" 
                                         ShowGridLines="False" Visibility="Hidden">

                                </DVC:LinearAxis>
                            </DVC:LineSeries.DependentRangeAxis>
                        </DVC:LineSeries>
                     
                        <DVC:LineSeries Name="SFPermissibleLowSeries"
                                IndependentValueBinding="{Binding Path=Key}"
                                DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True" Visibility="Visible" Width="Auto">

                            <DVC:LineSeries.DataPointStyle>
                                <Style TargetType="{x:Type DVC:LineDataPoint}">
                                    
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <Setter Property="Background" Value="Green"/>
                                  
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DVC:LineDataPoint">
                                                <Canvas x:Name="PlotArea"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DVC:LineSeries.DataPointStyle>

                            <DVC:LineSeries.LegendItemStyle>
                                <Style TargetType="{x:Type DVC:LegendItem}" >
                                    <Setter Property="Visibility" Value="Hidden"></Setter>
                                </Style>
                            </DVC:LineSeries.LegendItemStyle>
                            <DVC:LineSeries.DependentRangeAxis>
                                <DVC:LinearAxis x:Name="SFPermLow" Orientation="Y" 
                                    Title="Shear Force" 
                                         ShowGridLines="False" Visibility="Hidden">

                                </DVC:LinearAxis>
                            </DVC:LineSeries.DependentRangeAxis>
                        </DVC:LineSeries>
                    </DVC:Chart.Series>
                    <DVC:Chart.Axes>
                        <DVC:LinearAxis Orientation="X" 
                                    Title="Length (m)" 
                                        Maximum="100"
                                        Minimum="0"
                                       ShowGridLines="True" >
                        </DVC:LinearAxis>
                        
                    </DVC:Chart.Axes>
                </DVC:Chart>
            </Grid>
        </GroupBox>
    </Grid>
</Page>
