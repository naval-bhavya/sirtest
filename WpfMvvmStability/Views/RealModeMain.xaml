            <Setter Property="Foreground" Value="#030032"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Column cell style: disabled, red if damaged -->
        <Style x:Key="CellDamaged" TargetType="DataGridCell">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Foreground" Value="#030032"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
