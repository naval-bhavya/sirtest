                                    <DockPanel Name="dockPanelProfile" Background="White">
                                        <Controls:ZoomControl x:Name="zoomControlProfile" ZoomBoxBackground="{x:Null}" Background="White" Foreground="{x:Null}" Mode="Fill" ModifierMode="ZoomIn" MinZoom="3" MaxZoomDelta="5" RenderTransformOrigin="0,0">
