<!--<Page x:Class="WpfMvvmStability.Views.RealModeMain"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helix="http://helix-toolkit.org/wpf"
             xmlns:viewModels="clr-namespace:WpfMvvmStability.ViewModels"
             xmlns:Models="clr-namespace:WpfMvvmStability.Models.BO"
             xmlns:extbehaviour="clr-namespace:WPFExtensions.AttachedBehaviours;assembly=WPFExtensions"
            xmlns:cmd="clr-namespace:WPFExtensions.ViewModel.Commanding;assembly=WPFExtensions"
            xmlns:local="clr-namespace:WpfMvvmStability"
            xmlns:System="clr-namespace:System;assembly=mscorlib"
            xmlns:Controls="clr-namespace:WPFExtensions.Controls;assembly=WPFExtensions"
             mc:Ignorable="d" xmlns:my="clr-namespace:WpfMvvmStability" xmlns:my1="clr-namespace:WpfMvvmStability.Views" DataContext="{Binding}"  FontFamily="Calibri" Background="#F0F2F5" UseLayoutRounding="True" Height="730" Width="1300" Loaded="Page_Loaded">

    <Page.Resources>
        --><!-- ================= MODERN STYLES (Matching SimulationMode) ================= --><!--

        <Style TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Calibri" />
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
        </Style>

        --><!-- DataGridCell Style - All cells white background --><!--
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E6F7FF"/>
                    <Setter Property="BorderBrush" Value="#1890FF"/>
                    <Setter Property="Foreground" Value="#262626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        --><!-- DataGrid Style (Matching Simulation Mode) --><!--
        <Style TargetType="DataGrid" x:Key="ModernDataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F0F0F0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Calibri"/>
        </Style>

        --><!-- DataGrid Header Style --><!--
        <Style TargetType="DataGridColumnHeader" x:Key="ModernDataGridHeader">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Height" Value="26"/>
        </Style>

        --><!-- Button Styles --><!--
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" TargetName="Border" Value="#E6F7FF"/>
                                <Setter Property="BorderBrush" TargetName="Border" Value="#1890FF"/>
                                <Setter Property="Foreground" Value="#1890FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#1890FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1890FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#40A9FF"/>
                    <Setter Property="BorderBrush" Value="#40A9FF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        --><!-- Expander Style --><!--
        <Style TargetType="Expander">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        --><!-- TabControl Style --><!--
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        --><!-- TabItem Style --><!--
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#1890FF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        --><!-- Value Labels --><!--
        <Style TargetType="Label" x:Key="ValueLabel">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="BorderBrush" Value="#C8E6C9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="Label" x:Key="HeaderLabel">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="831*" />
            <ColumnDefinition Width="175*" />
            <ColumnDefinition Width="78*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="343*" />
            <RowDefinition Height="28*" />
            <RowDefinition Height="33*" />
            <RowDefinition Height="27*" />
            <RowDefinition Height="239*" />
        </Grid.RowDefinitions>

        <TabControl Name="tabControl2" 
            IsEnabled="True" 
            BorderBrush="#E0E0E0" 
            BorderThickness="0" 
            FontFamily="Calibri" 
            TabStripPlacement="Top" 
            VerticalContentAlignment="Stretch" 
            Foreground="#555" 
            Grid.ColumnSpan="3"
            Background="White">

            <TabControl.Resources>
                --><!-- Modern Color Palette (Matching SimulationMode) --><!--
                <SolidColorBrush x:Key="AppBackground" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="ContentBackground" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="TabBackground" Color="#E0E0E0"/>
                <SolidColorBrush x:Key="AccentBrush" Color="#1890FF"/>
                --><!-- Modern Blue Accent --><!--
                <SolidColorBrush x:Key="TextPrimary" Color="#555555"/>
                --><!-- Dark Text --><!--
                <SolidColorBrush x:Key="TextSecondary" Color="#999999"/>
                --><!-- Medium Gray Text --><!--
                <SolidColorBrush x:Key="CanvasPaper" Color="#FFFFFF"/>
                --><!-- White for Drawing Areas -->

                <!-- Style for Top Horizontal Tabs (Graphics 2D / 3D) - Matching SimulationMode --><!--
                <Style x:Key="MainTabItemStyle" TargetType="TabItem">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="15,8"/>
                    <Setter Property="Margin" Value="2,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid>
                                    <Border Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="4,4,0,0"
                                    Padding="{TemplateBinding Padding}">
                                        <ContentPresenter x:Name="ContentSite" 
                                                  VerticalAlignment="Center" 
                                                  HorizontalAlignment="Center" 
                                                  ContentSource="Header"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                --><!-- Style for Vertical Side Tabs (Right Side) - Matching SimulationMode --><!--
                <Style x:Key="VerticalTabItemStyle" TargetType="TabItem">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="15,8"/>
                    <Setter Property="Margin" Value="2,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid>
                                    <Border Name="Border" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="4,4,0,0"
                                    Padding="{TemplateBinding Padding}">
                                        <ContentPresenter x:Name="ContentSite" 
                                                  VerticalAlignment="Center" 
                                                  HorizontalAlignment="Center" 
                                                  ContentSource="Header">
                                            <ContentPresenter.LayoutTransform>
                                                <RotateTransform Angle="90" />
                                            </ContentPresenter.LayoutTransform>
                                        </ContentPresenter>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                --><!-- Modern Button Style - Matching SimulationMode --><!--
                <Style TargetType="Button" x:Key="ModernButtonStyle" BasedOn="{StaticResource PrimaryButton}">
                    <Setter Property="Background" Value="#1890FF"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="15,6"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#40A9FF"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#0050B3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

            </TabControl.Resources>

            --><!-- Main Tab 1: Graphics 2D --><!--
            <TabItem Header="Graphics 2D" Name="tabItem3" Style="{StaticResource MainTabItemStyle}">
                <Grid Background="{StaticResource ContentBackground}">

                    <TabControl Name="tabControl5" 
                        TabStripPlacement="Left" 
                        VerticalContentAlignment="Stretch" 
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0">

                        --><!-- Inner Tab: PROFILE --><!--
                        <TabItem Header="PROFILE" Name="tabItem7" Style="{StaticResource VerticalTabItemStyle}">
                            <Grid Background="{StaticResource ContentBackground}">
                                <DockPanel Name="dockPanelProfile" Background="{StaticResource ContentBackground}">
                                    <Controls:ZoomControl x:Name="zoomControlProfile" 
                                                ZoomBoxBackground="{x:Null}" 
                                                Background="{StaticResource ContentBackground}" 
                                                Foreground="{x:Null}" 
                                                Mode="Fill" 
                                                ModifierMode="ZoomIn" 
                                                MinZoom="3" 
                                                MaxZoomDelta="5" 
                                                RenderTransformOrigin="0,0">
                                        <Controls:ZoomControl.Resources>
                                            <Style TargetType="Slider">
                                                <Setter Property="Foreground" Value="DodgerBlue"/>
                                                <Setter Property="Background" Value="Aquamarine"/>
                                            </Style>
                                            <Style TargetType="{x:Type Rectangle}">
                                                <Setter Property="extbehaviour:DragBehaviour.IsDragEnabled" Value="True" />
                                                <Setter Property="extbehaviour:DragBehaviour.X" Value="{Binding RelativeSource={RelativeSource Self},Path=(Canvas.Left)}" />
                                                <Setter Property="extbehaviour:DragBehaviour.Y" Value="{Binding RelativeSource={RelativeSource Self},Path=(Canvas.Top)}" />
                                            </Style>
                                        </Controls:ZoomControl.Resources>
                                        <Grid Background="{StaticResource ContentBackground}" Width="185" Height="60">
                                            <Canvas Background="{StaticResource CanvasPaper}" Name="canvas2DProfile" RenderTransformOrigin="0,0" Margin="0.794,0,4.885,1.987"/>
                                        </Grid>
                                    </Controls:ZoomControl>
                                </DockPanel>
                            </Grid>
                        </TabItem>

                        --><!-- Inner Tab: D50|40 --><!--
                        <TabItem Header="D50|40" Name="tabItem8" Style="{StaticResource VerticalTabItemStyle}">
                            <Grid Background="{StaticResource ContentBackground}">
                                <DockPanel Name="dockPanelBottom" Background="{StaticResource ContentBackground}">
                                    <Controls:ZoomControl x:Name="zoomControlBottom" Background="{StaticResource ContentBackground}" MinZoom="3">
                                        <Grid Background="{StaticResource ContentBackground}" Width="176.25" Height="52.5">
                                            <Canvas Background="{StaticResource CanvasPaper}" Name="canvas2DPlanA" Margin="-0.135,-0.432,0.385,0.932"/>
                                        </Grid>
                                    </Controls:ZoomControl>
                                </DockPanel>
                            </Grid>
                        </TabItem>

                        --><!-- Inner Tab: D30|20 --><!--
                        <TabItem Header="D30|20" Name="tabItem9" Style="{StaticResource VerticalTabItemStyle}">
                            <Grid Background="{StaticResource ContentBackground}">
                                <DockPanel Name="dockPanelDeck" Background="{StaticResource ContentBackground}">
                                    <Controls:ZoomControl x:Name="zoomControlDeck" Background="{StaticResource ContentBackground}" MinZoom="3">
                                        <Grid Background="{StaticResource ContentBackground}" Width="176.25" Height="52.5">
                                            <Canvas Background="{StaticResource CanvasPaper}" Name="canvas2DPlanB"/>
                                        </Grid>
                                    </Controls:ZoomControl>
                                </DockPanel>
                            </Grid>
                        </TabItem>

                        --><!-- Inner Tab: D10|01 --><!--
                        <TabItem Header="D10|01" Name="tabItem10" Style="{StaticResource VerticalTabItemStyle}">
                            <Grid Background="{StaticResource ContentBackground}">
                                <DockPanel Background="{StaticResource ContentBackground}" Name="dockPanel1">
                                    <Controls:ZoomControl Background="{StaticResource ContentBackground}" Foreground="{x:Null}" Mode="Fill" ModifierMode="ZoomIn" Name="zoomControl1" ZoomBoxBackground="{x:Null}" Width="1025" MinZoom="3">
                                        <Controls:ZoomControl.Resources>
                                            <Style TargetType="{x:Type Rectangle}">
                                                <Setter Property="extbehaviour:DragBehaviour.IsDragEnabled" Value="True" />
                                                <Setter Property="extbehaviour:DragBehaviour.X" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Canvas.Left)}" />
                                                <Setter Property="extbehaviour:DragBehaviour.Y" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Canvas.Top)}" />
                                            </Style>
                                        </Controls:ZoomControl.Resources>
                                        <Grid Background="{StaticResource ContentBackground}" Height="52.5" Width="180">
                                            <Canvas Background="{StaticResource CanvasPaper}" Name="canvas2DPlanC" Margin="0,0,-0.031,0" />
                                        </Grid>
                                    </Controls:ZoomControl>
                                </DockPanel>
                            </Grid>
                        </TabItem>

                        --><!-- Inner Tab: ALL --><!--
                        <TabItem Header="ALL" Name="tabItem21" Style="{StaticResource VerticalTabItemStyle}">
                            <Grid Background="{StaticResource ContentBackground}">
                                <DockPanel Background="{StaticResource ContentBackground}" Name="dockPanel21">
                                    <Controls:ZoomControl Background="{StaticResource ContentBackground}" Foreground="{x:Null}" Mode="Fill" ModifierMode="ZoomIn" Name="zoomControl21" ZoomBoxBackground="{x:Null}" Width="1025" RenderTransformOrigin="0,0" MinZoom="3">
                                        <Controls:ZoomControl.Resources>
                                            <Style TargetType="{x:Type Rectangle}">
                                                <Setter Property="extbehaviour:DragBehaviour.IsDragEnabled" Value="True" />
                                                <Setter Property="extbehaviour:DragBehaviour.X" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Canvas.Left)}" />
                                                <Setter Property="extbehaviour:DragBehaviour.Y" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Canvas.Top)}" />
                                            </Style>
                                        </Controls:ZoomControl.Resources>
                                        <Grid Background="{StaticResource ContentBackground}" Height="52.5" Width="177.5">
                                            <Canvas Background="Transparent" Name="canvas2DPlanALL" Margin="0,0,-0.031,0" RenderTransformOrigin="0,0" Focusable="True" Opacity="9" />
                                        </Grid>
                                    </Controls:ZoomControl>
                                </DockPanel>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </TabItem>

            --><!-- Main Tab 2: Graphics 3D --><!--
            <TabItem Header="Graphics 3D" Name="tabItem6" Style="{StaticResource MainTabItemStyle}">
                <Grid Background="{StaticResource ContentBackground}">
                    --><!-- 3D Viewport with subtle border --><!--
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" Name="border2" Margin="10" CornerRadius="2">
                        <helix:HelixViewport3D x:Name="viewPort3d1" 
                                     ZoomExtentsWhenLoaded="False" 
                                     BorderBrush="Transparent" 
                                     BorderThickness="0" 
                                     RenderTransform="{Binding}" 
                                     ShowCoordinateSystem="True" 
                                     IsMoveEnabled="True" 
                                     IsManipulationEnabled="True" 
                                     IsTextSearchCaseSensitive="True" 
                                     IsTextSearchEnabled="True" 
                                     RotateAroundMouseDownPoint="False" 
                                     ZoomAroundMouseDownPoint="True"  
                                     Loaded="viewPort3d_Loaded" 
                                     ViewCubeWidth="80" 
                                     ShowCameraTarget="True">
                            <helix:HelixViewport3D.Background>
                                <ImageBrush ImageSource="/Stability;component/Images/Background.jpg" />
                            </helix:HelixViewport3D.Background>
                        </helix:HelixViewport3D>
                    </Border>

                    --><!-- Modern Zoom Button --><!--
                    <Button Content="Zoom Extents" 
                    Height="32" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,15,0" 
                    Name="btn3DZoomExtents" 
                    VerticalAlignment="Top" 
                    Width="140" 
                    Click="btn3DZoomExtents_Click" 
                    Style="{StaticResource ModernButtonStyle}" />
                </Grid>
            </TabItem>

        </TabControl>
        <TabControl Name="tabControl3" 
            Background="#F0F2F5" 
            BorderThickness="0" 
            Foreground="#555" 
            FontFamily="Calibri" 
            Grid.Row="1" 
            Grid.RowSpan="4" 
            Grid.Column="1" 
            Grid.ColumnSpan="2" 
            Margin="5">

            <TabControl.Resources>
                --><!-- Modern Palette (Matching SimulationMode) --><!--
                <SolidColorBrush x:Key="PanelBackground" Color="#F0F2F5"/>
                <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
                <SolidColorBrush x:Key="AccentColor" Color="#1890FF"/>
                <SolidColorBrush x:Key="ValueText" Color="#2E7D32"/>
                --><!-- Green for values --><!--
                <SolidColorBrush x:Key="LabelText" Color="#555555"/>
                <SolidColorBrush x:Key="HeaderBackground" Color="#F5F7FA"/>
                <SolidColorBrush x:Key="StatusText" Color="#52C41A"/>
                --><!-- Green for status -->

                <!-- Style for Value Labels (The Numbers) --><!--
                <Style x:Key="DataValueStyle" TargetType="Label">
                    <Setter Property="Foreground" Value="{StaticResource ValueText}"/>
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Setter Property="BorderBrush" Value="#C8E6C9"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Height" Value="28"/>
                </Style>

                --><!-- Style for Field Name Labels --><!--
                <Style x:Key="FieldLabelStyle" TargetType="Label">
                    <Setter Property="Foreground" Value="{StaticResource LabelText}"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                    <Setter Property="Padding" Value="5,0,10,0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>

                --><!-- Section Header Style --><!--
                <Style x:Key="SectionHeaderStyle" TargetType="Label">
                    <Setter Property="Foreground" Value="#555"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="Background" Value="{StaticResource HeaderBackground}"/>
                </Style>

                --><!-- Tab Item Style --><!--
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#555"/>
                    <Setter Property="Padding" Value="15,8"/>
                    <Setter Property="Margin" Value="2,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="{TemplateBinding Background}" CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" TextElement.FontSize="12"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                        <Setter Property="Foreground" Value="#1890FF"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="#999999"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Outputs" Name="tabItem4" Foreground="Black">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Background="{StaticResource PanelBackground}" Margin="0" Grid.IsSharedSizeScope="True">

                        --><!-- Section 1: General (Matches first Border in original) --><!--
                        <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="10,10,10,5" CornerRadius="4">
                            <Grid Margin="15,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Content="GMt(m)" Name="lebelGM" Style="{StaticResource FieldLabelStyle}" Grid.Row="0" Grid.Column="0"/>
                                <Label Name="lblGMT" Content="0" Style="{StaticResource DataValueStyle}" Grid.Row="0" Grid.Column="1"/>

                                <Label Content="Displacement(T)" Name="label1" Style="{StaticResource FieldLabelStyle}" Grid.Row="1" Grid.Column="0"/>
                                <Label Name="lblDisplacement" Content="0" Style="{StaticResource DataValueStyle}" Grid.Row="1" Grid.Column="1"/>
                            </Grid>
                        </Border>

                        --><!-- Section 2: Stability (Matches second Border in original) --><!--
                        <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="10,5" CornerRadius="4">
                            <Grid Margin="15,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
