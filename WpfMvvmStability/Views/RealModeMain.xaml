                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Graphics 2D -->
                <TabItem Header="Graphics 2D" Name="tabItem3" Style="{StaticResource MainTabItemStyle}">
                    <Grid Background="White">
                        <TabControl Name="tabControl5" TabStripPlacement="Left" Background="Transparent" BorderThickness="0">
                            <TabItem Header="PROFILE" Name="tabItem7" Style="{StaticResource VerticalTabItemStyle}">
