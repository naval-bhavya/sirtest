                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="KG(m)" Name="lbeGM" Style="{StaticResource HeaderLabel}" Grid.Row="0" Grid.Column="0"/>
                                        <Label Name="lblKG" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="0" Grid.Column="1" Margin="0,2"/>
                                        <Label Content="KGf(m)" Name="lobeGM" Style="{StaticResource HeaderLabel}" Grid.Row="1" Grid.Column="0"/>
                                        <Label Name="lblKGF" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="1" Grid.Column="1" Margin="0,2"/>
