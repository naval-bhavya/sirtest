                                <StackPanel>
                                    <Border Background="#030032" CornerRadius="4" Padding="8,4" Margin="0,0,0,8" HorizontalAlignment="Left">
                                        <TextBlock Text="Hydrostatics" Name="lblhydrostatics" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                    </Border>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
