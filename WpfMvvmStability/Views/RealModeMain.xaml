             mc:Ignorable="d" xmlns:my="clr-namespace:WpfMvvmStability" xmlns:my1="clr-namespace:WpfMvvmStability.Views" DataContext="{Binding}" FontFamily="Segoe UI" Background="#030032" UseLayoutRounding="True" Height="730" Width="1300" Loaded="Page_Loaded">

    <Page.Resources>
        <!-- ================= MODERN COLOR PALETTE ================= -->
        <Color x:Key="PrimaryColor">#1F48FF</Color>
        <Color x:Key="PrimaryLightColor">#4A6FFF</Color>
        <Color x:Key="PrimaryDarkColor">#1636CC</Color>
        <Color x:Key="PrimaryBgColor">#EEF1FF</Color>
        <Color x:Key="NavyColor">#030032</Color>
        <Color x:Key="PageBgColor">#F8F9FC</Color>
        <Color x:Key="CardBgColor">#FFFFFF</Color>
        <Color x:Key="BorderColor">#E2E5F0</Color>
        <Color x:Key="TextPrimaryColor">#030032</Color>
        <Color x:Key="TextSecondaryColor">#4A4A6A</Color>
        <Color x:Key="SuccessColor">#10B981</Color>
        <Color x:Key="DangerColor">#EF4444</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
        <SolidColorBrush x:Key="PrimaryBgBrush" Color="{StaticResource PrimaryBgColor}"/>
        <SolidColorBrush x:Key="NavyBrush" Color="{StaticResource NavyColor}"/>
        <SolidColorBrush x:Key="PageBgBrush" Color="{StaticResource PageBgColor}"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>

        <!-- TextBlock default -->
        <Style TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- DataGridRow default -->
        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="BorderBrush" Value="#F0F1F5"/>
        </Style>

        <!-- DataGridCell default -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF1FF"/>
                    <Setter Property="BorderBrush" Value="#1F48FF"/>
                    <Setter Property="Foreground" Value="#030032"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern DataGrid -->
        <Style TargetType="DataGrid" x:Key="ModernDataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
