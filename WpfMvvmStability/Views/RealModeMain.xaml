                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Label Content="AP" Name="label2" Style="{StaticResource HeaderLabel}" Grid.Row="0" Grid.Column="0"/>
                                            <Label Name="lblDraftAP" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="0" Grid.Column="1" Margin="0,2"/>
                                            <Label Content="Propeller" Name="label17" Style="{StaticResource HeaderLabel}" Grid.Row="1" Grid.Column="0"/>
                                            <Label Name="lblPROPELLER" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="1" Grid.Column="1" Margin="0,2"/>
                                            <Label Content="Aft Mark" Name="label12" Style="{StaticResource HeaderLabel}" Grid.Row="2" Grid.Column="0"/>
                                            <Label Name="lblDraftAftMark" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="2" Grid.Column="1" Margin="0,2"/>
                                            <Label Content="Mid" Name="label15" Style="{StaticResource HeaderLabel}" Grid.Row="3" Grid.Column="0"/>
                                            <Label Name="lblDraftMean" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="3" Grid.Column="1" Margin="0,2"/>
                                            <Label Content="Fwd Mark" Name="label14" Style="{StaticResource HeaderLabel}" Grid.Row="4" Grid.Column="0"/>
                                            <Label Name="lblDraftFwdMark" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="4" Grid.Column="1" Margin="0,2"/>
                                            <Label Content="Sonar Dome" Name="label16" Style="{StaticResource HeaderLabel}" Grid.Row="5" Grid.Column="0"/>
                                            <Label Name="lblSONARDOME" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="5" Grid.Column="1" Margin="0,2"/>
                                            <Label Content="FP" Name="label7" Style="{StaticResource HeaderLabel}" Grid.Row="6" Grid.Column="0"/>
                                            <Label Name="lblDraftFP" Content="0" Style="{StaticResource ValueLabel}" Grid.Row="6" Grid.Column="1" Margin="0,2"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Hydrostatics -->
