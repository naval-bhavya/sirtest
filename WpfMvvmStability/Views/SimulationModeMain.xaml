                <Border Grid.Row="0" Grid.Column="1" Margin="6,4,5,6">
            <Border Background="{DynamicResource CardBgBrush}" BorderBrush="#3B82F6" BorderThickness="1.5" CornerRadius="10" Padding="12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.04" Color="#030032"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="2,0,12,0">
                        <TextBlock Text="Calculation Progress" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse x:Name="progressStatusDot" Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtProgressStatus" Text="Ready" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Row="0" Grid.Column="1" Content="Calculate" x:Name="btnCalculate" Click="btnCalculate_Click" FontWeight="Bold" FontSize="12" Padding="18,8" Height="40" MinWidth="132" Foreground="White" Background="#1F48FF" BorderBrush="#1F48FF" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.18" Color="#1F48FF"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" TargetName="Border" Value="#4A6FFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" TargetName="Border" Value="#1636CC"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="#EDF4FF" BorderBrush="#C7DAFF" BorderThickness="1" CornerRadius="10" Padding="10,8" Margin="0,10,0,0">
                        <Grid>
                            <ProgressBar x:Name="pRGSCalculation" Height="14" Minimum="0" Maximum="100" Value="8" Background="#D8E4FF" Foreground="#1F48FF"/>
                            <TextBlock x:Name="txtProgressPercent" Text="Ready" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="11" Foreground="#1636CC"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- Right-side outputs panel:
             Shows calculated stability results, loading details, and hydrostatic values at a glance. -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="6,0,5,5" Background="{DynamicResource CardBgBrush}" CornerRadius="12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="0.5" Opacity="0.01" Color="#030032"/>
            </Border.Effect>
            <TabControl x:Name="tabControl3" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource TankPanelTabItemStyle}"/>
                </TabControl.Resources>
                <TabItem x:Name="tabItem4" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8,4,8,8">
                                <!-- Action Buttons -->
                                <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,0,5">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="0.5" Opacity="0.008" Color="#030032"/>
                                    </Border.Effect>
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Import" x:Name="btnImportRealModeData" Click="btnImportRealModeData_Click" Height="34" HorizontalAlignment="Stretch" Background="#1F48FF" Foreground="White" BorderBrush="#7EA2FF" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                                        <Button Grid.Column="2" Content="Save" x:Name="btnSaveLoadingCondition" Click="btnSaveLoadingCondition_Click" Height="34" HorizontalAlignment="Stretch" Background="#10B981" Foreground="White" BorderBrush="#7AE0BB" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                                        <Button Grid.Column="4" Content="Clear" x:Name="btnclear" Click="btnclear_Click" Height="34" HorizontalAlignment="Stretch" Background="#EF4444" Foreground="White" BorderBrush="#FFB0B0" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <!-- Output Panels Grid -->
                                <Grid Margin="0,6,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: Stability Summary -->
                                    <Grid Grid.Row="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Stability Summary Box -->
                                        <Border Grid.Row="0" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="0.5" Opacity="0.008" Color="#030032"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                                                    <TextBlock Text="Stability Summary" FontWeight="Bold" Foreground="White" FontSize="12" Margin="2,0,0,0"/>
                                                </Border>
                                                <Grid Margin="2,0,2,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="118"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Label Grid.Row="0" Grid.Column="0" Content="GMt (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="0" Grid.Column="1" x:Name="lblGMT" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <Label Grid.Row="1" Grid.Column="0" Content="Displacement (T)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="1" Grid.Column="1" x:Name="lblDisplacement" Content="0" Style="{StaticResource ValueLabel}" Margin="0,8,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Row 2: Drafts & Trim -->
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Drafts & Trim Box -->
                                        <Border Grid.Row="0" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="0.5" Opacity="0.008" Color="#030032"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                                                    <TextBlock Text="Drafts &amp; Trim" FontWeight="Bold" Foreground="White" FontSize="12" Margin="2,0,0,0"/>
                                                </Border>
                                                <Grid Margin="2,0,2,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="118"/>
                                                        <ColumnDefinition Width="54"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="12"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="12"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Label Grid.Row="0" Grid.Column="0" Content="Trim (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="0" Grid.Column="1" x:Name="lblTrim" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="FWD" Foreground="#10B981" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Label Grid.Row="1" Grid.Column="0" Content="List (deg.)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="1" Grid.Column="1" x:Name="lblHeel" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="STBD" Foreground="#10B981" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4,0,4"/>
                                                    <Label Grid.Row="3" Grid.Column="0" Content="AP (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="3" Grid.Column="1" x:Name="lblDraftAP" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <Label Grid.Row="4" Grid.Column="0" Content="FP (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="4" Grid.Column="1" x:Name="lblDraftFP" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <Label Grid.Row="5" Grid.Column="0" Content="Mid (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="5" Grid.Column="1" x:Name="lblDraftMean" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <Border Grid.Row="6" Grid.ColumnSpan="3" Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4,0,4"/>
                                                    <Label Grid.Row="7" Grid.Column="0" Content="Aft Mark (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="7" Grid.Column="1" x:Name="lblDraftAftMark" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <Label Grid.Row="8" Grid.Column="0" Content="Fwd Mark (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="8" Grid.Column="1" x:Name="lblDraftFwdMark" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <Label Grid.Row="9" Grid.Column="0" Content="Propeller (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="9" Grid.Column="1" x:Name="lblPROPELLER" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                    <Label Grid.Row="10" Grid.Column="0" Content="Sonar Dome (m)" Style="{StaticResource HeaderLabel}"/>
                                                    <Label Grid.Row="10" Grid.Column="1" x:Name="lblSONARDOME" Content="0" Style="{StaticResource ValueLabel}" Margin="0,2"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Row 3: Hydrostatics -->
                                    <Grid Grid.Row="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
