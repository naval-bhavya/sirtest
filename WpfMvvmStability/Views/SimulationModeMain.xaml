                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Fixed Load Tab -->
                <TabItem Header="Fixed Load" Name="tabItem11">
                    <DockPanel Margin="0,0,5,0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,5,10">
                            <Button Content="ADD" Name="btnAdd" Width="70" Style="{StaticResource PrimaryButton}" Click="btnAdd_Click" Margin="0,0,5,0" Padding="10,4"/>
                            <Button Content="REMOVE" Name="btnRemove" Width="80" Style="{StaticResource ClearButton}" Click="btnRemove_Click" Padding="10,4"/>
                        </StackPanel>
                        <DataGrid Name="dgVariableItems" Style="{StaticResource ModernDataGrid}" ColumnHeaderStyle="{StaticResource ModernDataGridHeader}"
                                  CanUserAddRows="False" CanUserResizeColumns="False" CanUserResizeRows="False" CanUserSortColumns="False" 
                                  AutoGenerateColumns="False" IsReadOnly="False" 
                                  PreparingCellForEdit="dgTankCompartment_PreparingCellForEdit" 
                                  SelectionChanged="dgVariableItems_SelectionChanged" 
                                  BeginningEdit="dgVariableItems_BeginningEdit" 
                                  CurrentCellChanged="dgVariableItems_CurrentCellChanged" 
                                  LoadingRow="dgVariableItems_LoadingRow" 
                                  KeyDown="dgVariableItems_KeyDown"
                                  HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item Name" Binding="{Binding Path=Load_Name}" Width="2*" IsReadOnly="True"/>
                                <DataGridTextColumn Binding="{Binding Path=Weight, StringFormat=\{0:0.00\}}" Header="Weight(t)" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Path=LCG, StringFormat=\{0:0.00\}}" Header="LCG(m)" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Path=VCG, StringFormat=\{0:0.00\}}" Header="VCG(m)" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Path=TCG, StringFormat=\{0:0.00\}}" Header="TCG(m)" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Path=Length,StringFormat=\{0:0.00\}}" Header="Length(m)" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Path=Breadth, StringFormat=\{0:0.00\}}" Header="Breadth(m)" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Path=Depth, StringFormat=\{0:0.00\}}" Header="Depth(m)" Width="*"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="{x:Type DataGridRow}">
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBgBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Border>

