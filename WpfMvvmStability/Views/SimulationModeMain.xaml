                    <Button Content="Zoom extents" Height="23" HorizontalAlignment="Left" Margin="948,16,0,0" Name="btn3DZoomExtents" VerticalAlignment="Top" Width="112.778" Click="btn3DZoomExtents_Click" Background="#00000000" />
