                                            <Grid Background="#FFFFFF" Width="176.25" Height="52.5" Margin="5">
                                                <Canvas Background="#FFFFFF" Name="canvas2DPlanA" Opacity="90"/>
                                            </Grid>
                                        </Controls:ZoomControl>
                                    </DockPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="D30|20" Name="tabItem9">
