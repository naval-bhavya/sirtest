                                                <Canvas Background="#FFFFFF" Name="canvas2DProfile" MouseRightButtonDown="canvas2DProfile_MouseRightButtonDown_1" Margin="0,0,-14,0"/>
                                            </Grid>
                                        </Controls:ZoomControl>
                                    </DockPanel>
                                </Grid>
                            </TabItem>

