                                    <DockPanel Name="dockPanelDeck">
                                        <Controls:ZoomControl x:Name="zoomControlDeck" MinZoom="3" Background="#F8F9FC">
                                            <Grid Background="#FFFFFF" Width="176.25" Height="52.5" Margin="5">
                                                <Canvas Background="#FFFFFF" Name="canvas2DPlanB"/>
                                            </Grid>
                                        </Controls:ZoomControl>
                                    </DockPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="D10|0" Name="tabItem12">
                                <Grid Background="#F8F9FC">
                                    <DockPanel Background="#F8F9FC" Name="dockPanel1">
                                        <Controls:ZoomControl Name="zoomControl1" Mode="Fill" ModifierMode="ZoomIn" MinZoom="3" Background="#F8F9FC">
                                            <Grid Background="#FFFFFF" Height="52.5" Width="180" Margin="5">
                                                <Canvas Background="#FFFFFF" Name="canvas2DPlanC"/>
                                            </Grid>
                                        </Controls:ZoomControl>
                                    </DockPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="ALL" Name="tabItem15">
                                <Grid Background="#F8F9FC">
                                    <DockPanel Name="dockPanelAll">
                                        <Controls:ZoomControl x:Name="zoomControlAll" Mode="Fill" ModifierMode="ZoomIn" MinZoom="3" Background="#F8F9FC">
                                            <Grid Background="#FFFFFF" Width="177.5" Height="52.5" Margin="5">
                                                <Canvas Background="#FFFFFF" Name="canvas2DAll"/>
                                            </Grid>
                                        </Controls:ZoomControl>
                                    </DockPanel>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <!-- Graphics 3D -->
                <TabItem Header="Graphics 3D" Name="tabItem6" >
                <Grid>
                    <Border BorderBrush="Silver" BorderThickness="1" Name="border2">
                        <hx:Viewport3DX x:Name="viewPort3d"
                            ShowCoordinateSystem="True"
                            ZoomAroundMouseDownPoint="False"
                            RotateAroundMouseDownPoint="False"
                            CameraRotationMode="Trackball"
                            Loaded="viewPort3d_Loaded"
                            BackgroundColor="White">
                            <hx:Viewport3DX.Camera>
                                <hx:PerspectiveCamera Position="170000,-90000,80000"
                                    LookDirection="-100000,90000,-90000"
                                    UpDirection="0,0,1"
                                    FieldOfView="45"
                                    NearPlaneDistance="10"
                                    FarPlaneDistance="1000000"/>
                            </hx:Viewport3DX.Camera>
                            <hx:DirectionalLight3D Direction="-1,-1,-1" Color="White"/>
                            <hx:AmbientLight3D Color="#666666"/>
                            <hx:GroupModel3D x:Name="scene3D"/>
                        </hx:Viewport3DX>
                    </Border>
                    <StackPanel Margin="8,0,3,8" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Tankname, StringFormat='Tank Name: {0}'}"/>
                        <TextBlock Text="{Binding volume, StringFormat='Volume: {0}'}"/>
                        <TextBlock Text="{Binding percent, StringFormat='Percent Fill: {0} %'}"/>
                        <TextBlock Text="{Binding status, StringFormat='Status: {0}'}"/>
