<UserControl x:Class="WpfMvvmStability.Views.TankGridShell"
             x:Name="shellRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:views="clr-namespace:WpfMvvmStability.Views"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200">
    <Grid>
        <Border Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1.2"
                CornerRadius="14"
                Padding="4">
            <ContentPresenter Content="{Binding BodyContent, ElementName=shellRoot}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>
        </Border>
    </Grid>
</UserControl>
