<Page x:Class="WpfMvvmStability.Views.CorrectiveAction"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:DV="clr-namespace:System.Windows.Controls.DataVisualization;assembly=System.Windows.Controls.DataVisualization.Toolkit"
      xmlns:DVC="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=System.Windows.Controls.DataVisualization.Toolkit"
      xmlns:chartPrimitive="clr-namespace:System.Windows.Controls.DataVisualization.Charting.Primitives;assembly=System.Windows.Controls.DataVisualization.Toolkit"
      mc:Ignorable="d" Title="CorrectiveAction"
      xmlns:my="clr-namespace:WPFExtensions.Controls;assembly=WPFExtensions"
      xmlns:my1="clr-namespace:WPFExtensions.AttachedBehaviours;assembly=WPFExtensions"
      xmlns:h="http://helix-toolkit.org/wpf"
      xmlns:oxy="http://oxyplot.org/wpf">

    <Page.Resources>

        <!-- Calculation Button -->
        <Style x:Key="CalcButton" TargetType="Button">
            <Setter Property="Background" Value="#1F48FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Run All Button -->
        <Style x:Key="RunAllButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
            <Setter Property="Background" Value="#030032"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="40,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Modern ListBox -->
        <Style x:Key="ModernListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#2D3142"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="MinHeight" Value="44"/>
        </Style>

    </Page.Resources>

    <Grid Background="#F0F2F8">

        <!-- Hidden legacy elements kept for code-behind compatibility -->
        <GroupBox Name="groupBox1" Visibility="Collapsed" Width="0" Height="0">
            <DataGrid Name="listBox1"/>
        </GroupBox>
        <GroupBox Name="groupBox3" Visibility="Collapsed" Width="0" Height="0">
            <DataGrid Name="listBox2"/>
        </GroupBox>
        <GroupBox Name="groupBox7" Visibility="Collapsed" Width="0" Height="0">
            <Grid>
                <DVC:Chart Name="GzChart" Background="Transparent">
                    <DVC:Chart.Series>
                        <DVC:LineSeries Name="GZSeries" Title="GZ"
                                IndependentValueBinding="{Binding Path=Key}"
                                DependentValueBinding="{Binding Path=Value}"
                                ItemsSource="{Binding}" IsSelectionEnabled="True">
                            <DVC:LineSeries.DataPointStyle>
                                <Style TargetType="{x:Type DVC:LineDataPoint}">
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <Setter Property="Background" Value="Red"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DVC:LineDataPoint">
                                                <Canvas x:Name="PlotArea"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DVC:LineSeries.DataPointStyle>
                        </DVC:LineSeries>
                    </DVC:Chart.Series>
                    <DVC:Chart.Axes>
                        <DVC:LinearAxis Orientation="Y" Title="GZ (m)" Maximum="3" Minimum="-2" ShowGridLines="True"/>
                        <DVC:LinearAxis Orientation="X" Title="Heel(deg.)" Maximum="120" Minimum="-25" ShowGridLines="True"/>
                        <DVC:CategoryAxis/>
                    </DVC:Chart.Axes>
                </DVC:Chart>
            </Grid>
        </GroupBox>

        <!-- Main Layout -->
        <Grid Margin="0,10,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Scrollable Sections -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- De-flooding Options -->
                    <Border Background="White" BorderBrush="#E2E5F0" BorderThickness="1"
                            CornerRadius="0" Margin="0,0,0,6">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.06" Color="#030032"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Background="#030032" CornerRadius="0" Padding="12,8">
                                <TextBlock Text="De-flooding Options" Foreground="White"
                                           FontWeight="SemiBold" FontSize="13" FontFamily="Segoe UI"/>
                            </Border>
                            <ListBox Name="listBoxDeDlooting" Style="{StaticResource ModernListBox}"/>
                        </StackPanel>
                    </Border>

                    <!-- Ballasting Options -->
                    <Border Background="White" BorderBrush="#E2E5F0" BorderThickness="1"
                            CornerRadius="0" Margin="0,0,0,6">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.06" Color="#030032"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Background="#030032" CornerRadius="0" Padding="12,8">
                                <Grid>
                                    <TextBlock Text="Ballasting Options" Foreground="White"
                                               FontWeight="SemiBold" FontSize="13" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <Button Name="btnballastcalc" Content="BALLAST CALCULATION"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource CalcButton}"
                                            Click="btnballastcalc_Click"/>
                                </Grid>
                            </Border>
                            <ListBox Name="listBoxBallastCorrectiveMeasures" Style="{StaticResource ModernListBox}"/>
                        </StackPanel>
                    </Border>

                    <!-- Deballasting Options -->
                    <Border Background="White" BorderBrush="#E2E5F0" BorderThickness="1"
                            CornerRadius="0" Margin="0,0,0,6">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.06" Color="#030032"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Background="#030032" CornerRadius="0" Padding="12,8">
                                <Grid>
                                    <TextBlock Text="Deballasting Options" Foreground="White"
                                               FontWeight="SemiBold" FontSize="13" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <Button Name="btndeballastcalc" Content="DEBALLAST CALCULATION"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource CalcButton}"
                                            Click="btndeballastcalc_Click"/>
                                </Grid>
                            </Border>
                            <ListBox Name="listBox3" Style="{StaticResource ModernListBox}"/>
                        </StackPanel>
                    </Border>

                    <!-- Fluid Transfer — Freshwater -->
                    <Border Background="White" BorderBrush="#E2E5F0" BorderThickness="1"
                            CornerRadius="0" Margin="0,0,0,6">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.06" Color="#030032"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Background="#030032" CornerRadius="0" Padding="12,8">
                                <Grid>
                                    <TextBlock Text="Fluid Transfer Options — Freshwater" Foreground="White"
                                               FontWeight="SemiBold" FontSize="13" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <Button Name="btnFlTransfer" Content="FW TRANSFER CALCULATION"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource CalcButton}"
                                            Click="btnFlTransfer_Click_1"/>
                                </Grid>
                            </Border>
                            <ListBox Name="listBox4" Style="{StaticResource ModernListBox}"/>
                        </StackPanel>
                    </Border>

                    <!-- Fluid Transfer — Fuel Oil -->
                    <Border Background="White" BorderBrush="#E2E5F0" BorderThickness="1"
                            CornerRadius="0" Margin="0,0,0,6">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.06" Color="#030032"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Background="#030032" CornerRadius="0" Padding="12,8">
                                <Grid>
                                    <TextBlock Text="Fluid Transfer Options — Fuel Oil" Foreground="White"
                                               FontWeight="SemiBold" FontSize="13" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <Button Name="btnFuelTransfer" Content="FO TRANSFER CALCULATION"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource CalcButton}"
                                            Click="btnfuelFlTransfer_Click_1"/>
                                </Grid>
                            </Border>
                            <ListBox Name="listBox5" Style="{StaticResource ModernListBox}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Action Bar -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E2E5F0"
                    BorderThickness="0,1,0,0" Padding="0,12,0,0">
                <Button Name="btnAllCorrective" Content="RUN ALL CORRECTIVE ACTIONS"
                        Style="{StaticResource RunAllButton}"
                        HorizontalAlignment="Center"
                        Click="btnAllCorrective_Click"/>
            </Border>

        </Grid>
    </Grid>
</Page>
