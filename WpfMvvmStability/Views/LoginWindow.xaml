<Window x:Class="WpfMvvmStability.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Login" FontSize="13" WindowStartupLocation="CenterScreen"
        WindowState="Normal" mc:Ignorable="d" Height="260" Width="560"
        Focusable="True" ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="106"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Background" Value="#1F48FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" BorderBrush="#DDE5FF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.18" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1F48FF" CornerRadius="12,12,0,0">
                <Grid>
                    <TextBlock Text="Login" Foreground="White" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="22,0,60,0"/>
                    <Button Content="X" Width="34" Height="34" HorizontalAlignment="Right"
                            Margin="0,0,14,0" Background="Transparent" Foreground="White"
                            BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="btncancel_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Name="grdLogin" Margin="28,24,28,26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="118"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                        Width="86" Height="86" Background="#EEF4FF" CornerRadius="43"
                        HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Image Name="image1" Stretch="Uniform" Width="52" Height="52"
                           Source="/Stability;component/Images/loginIcon.png"/>
                </Border>

                <Label Grid.Row="0" Grid.Column="1" Name="label1"
                       Content="Please Login to Access" FontWeight="Bold" FontSize="16"
                       Foreground="#111827" HorizontalContentAlignment="Center" Padding="0,4,0,18"/>

                <Grid Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Name="label2" Content="Password"
                           Foreground="#111827" VerticalContentAlignment="Center"/>
                    <TextBox Grid.Column="1" Name="txtPaswword" Style="{StaticResource InputBox}"/>
                </Grid>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="Login" Name="btnlogin" Style="{StaticResource DialogButton}" Click="btnLogin"/>
                    <Button Content="Reset Password" Name="btnReset" Style="{StaticResource DialogButton}" MinWidth="138" Click="btnResetPwd"/>
                    <Button Content="Cancel" Name="btncancel" Style="{StaticResource DialogButton}" Background="#6B7280" Click="btncancel_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Name="grdResetPWD" Margin="28,24,28,26" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="118"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                        Width="86" Height="86" Background="#EEF4FF" CornerRadius="43"
                        HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Image Name="image2" Stretch="Uniform" Width="52" Height="52"
                           Source="/Stability;component/Images/loginIcon1.png"/>
                </Border>

                <Label Grid.Row="0" Grid.Column="1" Name="label3"
                       Content="Reset Password" FontSize="16" FontWeight="Bold"
                       Foreground="#111827" HorizontalContentAlignment="Center" Padding="0,4,0,18"/>

                <Grid Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Name="label4" Content="Default Password"
                           Foreground="#111827" VerticalContentAlignment="Center"/>
                    <TextBox Grid.Column="1" Name="txtdefaultPaswword" Style="{StaticResource InputBox}"/>
                </Grid>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="OK" Name="btnOK" Style="{StaticResource DialogButton}" Click="btnOK_Click"/>
                    <Button Content="Cancel" Style="{StaticResource DialogButton}" Background="#6B7280" Click="btncancel_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
