<UserControl x:Class="WpfMvvmStability.Views.TankControlsHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:WpfMvvmStability.Views"
             mc:Ignorable="d"
             d:DesignHeight="88"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <Style x:Key="TankControlsChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource InnerBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,8,6"/>
        </Style>
        <Style x:Key="TankControlsBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PrimaryBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="TankControlsPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource NavyBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="10,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="14,10" Margin="0,0,0,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.08" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType={x:Type views:TankControlsHeader}}}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontFamily="Segoe UI"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding DescriptionText, RelativeSource={RelativeSource AncestorType={x:Type views:TankControlsHeader}}}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource TankControlsBadgeStyle}" Margin="0,0,10,0">
                    <TextBlock Text="{Binding BadgeText, RelativeSource={RelativeSource AncestorType={x:Type views:TankControlsHeader}}}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                <Border Style="{StaticResource TankControlsPillStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText, RelativeSource={RelativeSource AncestorType={x:Type views:TankControlsHeader}}}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0" VerticalAlignment="Center">
                <Border Style="{StaticResource TankControlsChipStyle}">
                    <TextBlock Text="{Binding ChipText, RelativeSource={RelativeSource AncestorType={x:Type views:TankControlsHeader}}}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </WrapPanel>
        </Grid>
    </Border>
</UserControl>
