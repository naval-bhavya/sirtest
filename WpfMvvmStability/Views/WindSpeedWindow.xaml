<Window x:Class="WpfMvvmStability.Views.WindSpeedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wind Speed Settings" Height="300" Width="500" 
        FontFamily="Segoe UI" WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Loaded="Window_Loaded">
    <Border Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#2563EB" CornerRadius="10,10,0,0">
                <Grid>
                    <TextBlock Text="Wind Speed Settings" 
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="22,0,56,0"/>
                    <Button Content="X" Width="35" Height="35" 
                            Background="Transparent" Foreground="White"
                            FontSize="18" FontWeight="Bold" Cursor="Hand"
                            HorizontalAlignment="Right" Margin="0,0,10,0"
                            Click="btnExit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent" CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="30,25,30,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    
                    <Label Grid.Column="0" Content="Wind Speed (Knots)" 
                           Foreground="#1F2937" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                    
                    <TextBox Grid.Column="1" x:Name="txtWindSpped" 
                             Height="40" FontSize="14"
                             Background="#F9FAFB" BorderBrush="#D1D5DB"
                             Padding="15,10" VerticalContentAlignment="Center"
                             BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Grid>
            </StackPanel>
            
            <!-- Footer Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,0,30,0">
                <Button Content="Exit" Width="100" Height="40"
                        Background="#6B7280" Foreground="White"
                        FontSize="14" FontWeight="SemiBold"
                        Margin="0,0,15,0" Cursor="Hand"
                        Click="btnExit_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Content="Update" Width="120" Height="40"
                        Background="#2563EB" Foreground="White"
                        FontSize="14" FontWeight="SemiBold"
                        Cursor="Hand" Click="btnWindSppedUpdate_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
