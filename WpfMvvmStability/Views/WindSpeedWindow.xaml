<Window x:Class="WpfMvvmStability.Views.WindSpeedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindSpeedWindow" Height="223" Width="398" FontFamily="Calibri" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" BorderBrush="Black" Loaded="Window_Loaded">
    <Grid Height="185" Background="LightGray">
        <StackPanel Name="stackPanel2" Width="376">
            <DockPanel Height="36" Name="dockPanel1" Width="376">
                <Label Content="Wind Speed " Height="36" Name="lblStabilitySettings" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16" />
            </DockPanel>
            <StackPanel Height="84" Name="stackPanel1" Width="374">
                <Grid Height="84" Name="grid1" Width="374">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30*" />
                        <ColumnDefinition Width="158*" />
                        <ColumnDefinition Width="150*" />
                        <ColumnDefinition Width="36*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16*" />
                        <RowDefinition Height="34*" />
                        <RowDefinition Height="14*" />
                    </Grid.RowDefinitions>
                    <Label Content="Wind Speed (Knots)" Height="38" Name="label1" Grid.Row="1" Grid.Column="1" Margin="54,0,126,7" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Grid.ColumnSpan="2" />
                    <TextBox Grid.Column="2" Grid.Row="1" Height="23" Margin="45,7,53,12" Name="txtWindSpped" BorderThickness="2" BorderBrush="Black" />
                </Grid>
            </StackPanel>
            <DockPanel Height="64" Name="dockPanel2" Width="376">
                <Button Content="WIND SPEED UPDATE" Height="43" Name="btnWindSppedUpdate" Width="179" Margin=" 10,10,10,10" Click="btnWindSppedUpdate_Click" />
                <Button Content="Ok" Height="43" Name="btnOk" Width="75" Margin=" 0,10,10,10" Click="btnOk_Click" />
                <Button Content="Exit" Height="43" Name="btnExit" Width="75"  Margin=" 0,10,10,10" Click="btnExit_Click" />
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
