<UserControl x:Class="WpfMvvmStability.Views.ModernMessageBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Border Background="White" CornerRadius="12" BorderBrush="#DDE5FF" BorderThickness="1" MinWidth="380" MaxWidth="560">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.18" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <Border x:Name="HeaderBorder" Grid.Row="0" CornerRadius="12,12,0,0">
                <Grid>
                    <TextBlock x:Name="txtTitle"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="22,0,56,0"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Content="X" Width="35" Height="35"
                            Background="Transparent" Foreground="White"
                            FontSize="14" FontWeight="Bold" Cursor="Hand"
                            HorizontalAlignment="Right" Margin="0,0,10,0"
                            Click="btnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent" CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="28,24,28,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="IconBorder" Grid.Column="0"
                        CornerRadius="18" Width="46" Height="46"
                        HorizontalAlignment="Center" VerticalAlignment="Top">
                    <TextBlock x:Name="txtIcon" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="txtMessage" Grid.Column="1"
                           Foreground="#1F2937" FontSize="15" LineHeight="22"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           TextWrapping="Wrap"/>
            </Grid>

            <Border Grid.Row="2" Background="#F8FAFF" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="24,0">
                    <Button x:Name="btnCancel" Content="Cancel" Width="108" Height="40"
                            Background="#E5E7EB" Foreground="#374151" FontSize="14" FontWeight="SemiBold"
                            Margin="0,0,10,0" Cursor="Hand" Visibility="Collapsed" Click="btnCancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="7">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#D1D5DB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnNo" Content="No" Width="108" Height="40"
                            Background="#6B7280" Foreground="White" FontSize="14" FontWeight="SemiBold"
                            Margin="0,0,10,0" Cursor="Hand" Visibility="Collapsed" Click="btnNo_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="7">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnOK" Content="OK" Width="108" Height="40"
                            Foreground="White" FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand" Click="btnOK_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="7">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
