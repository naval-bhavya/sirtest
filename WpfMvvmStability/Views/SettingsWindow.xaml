<Window x:Class="WpfMvvmStability.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SettingsWindow" Height="276" Width="398" FontFamily="Calibri" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" BorderBrush="Black">
    <Grid Height="239" Background="LightGray">
        <StackPanel Name="stackPanel2" Width="376">
            <DockPanel Height="54" Name="dockPanel1" Width="376">
                <Label Content="Stability Settings " Height="52" Name="lblStabilitySettings" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16" Loaded="lblStabilitySettings_Loaded" />
            </DockPanel>
            <StackPanel Height="120" Name="stackPanel1" Width="374">
                <Grid Height="120" Name="grid1" Width="374">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30*" />
                        <ColumnDefinition Width="158*" />
                        <ColumnDefinition Width="150*" />
                        <ColumnDefinition Width="36*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16*" />
                        <RowDefinition Height="39*" />
                        <RowDefinition Height="15*" />
                        <RowDefinition Height="36*" />
                        <RowDefinition Height="14*" />
                    </Grid.RowDefinitions>
                    <Label Content="High Low Alarm level" Height="38" Name="label1" Grid.Row="1" Grid.Column="1" Margin="0,1,0,0" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" />
                    <Label Content="Flood Rate(Cu. M/ S)" Height="36" HorizontalAlignment="Left" Name="label2" VerticalAlignment="Top" Width="158" Grid.Row="3" Grid.Column="1" VerticalContentAlignment="Center" />
                    <TextBox Grid.RowSpan="2" Margin="0,0,0,12" Name="txtFldRate" Grid.Column="2" Grid.Row="3" BorderBrush="Black" Height="23" />
                    <ComboBox Grid.Column="2" Grid.Row="1" Height="23" HorizontalAlignment="Left" Margin="0,8,0,0" Name="cmbHighLow" VerticalAlignment="Top" Width="150" BorderBrush="Black" HorizontalContentAlignment="Left">
                        <ComboBoxItem Content="0" />
                        <ComboBoxItem Content="1" />
                    </ComboBox>
                </Grid>
            </StackPanel>
            <DockPanel Height="64" Name="dockPanel2" Width="376">
                <Button Content="Result Stability calculation" Height="43" Name="btnResStabilitycal" Width="179" Margin=" 10,10,10,10" Click="btnResStabilitycal_Click" />
                <Button Content="Ok" Height="43" Name="btnOk" Width="75" Margin=" 0,10,10,10" Click="btnOk_Click" />
                <Button Content="Exit" Height="43" Name="btnExit" Width="75"  Margin=" 0,10,10,10" Click="btnExit_Click" />
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
