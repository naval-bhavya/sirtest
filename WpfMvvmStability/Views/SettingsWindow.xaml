<Window x:Class="WpfMvvmStability.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="600" Width="500" 
        FontFamily="Segoe UI" WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    <Border Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#2563EB" CornerRadius="10,10,0,0">
                <Grid>
                    <TextBlock Text="⚙️ Settings" 
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="20,0,0,0"/>
                    <Button Content="✕" Width="35" Height="35" 
                            Background="Transparent" Foreground="White"
                            FontSize="18" FontWeight="Bold" Cursor="Hand"
                            HorizontalAlignment="Right" Margin="0,0,10,0"
                            Click="btnExit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent" CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="30,20,30,20">
                    <!-- Database Configuration Section -->
                    <TextBlock Text="Database Configuration" 
                               Foreground="#2563EB" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,15"/>
                    
                    <Border Background="#F9FAFB" CornerRadius="8" Padding="20" Margin="0,0,0,20"
                            BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <!-- Server Name -->
                            <StackPanel Margin="0,0,0,15">
                                <Label Content="Server Name" 
                                       Foreground="#1F2937" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="txtServer" Height="40" FontSize="14"
                                         Background="White" BorderBrush="#D1D5DB"
                                         Padding="15,10" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                            
                            <!-- User ID -->
                            <StackPanel Margin="0,0,0,15">
                                <Label Content="User ID" 
                                       Foreground="#1F2937" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="txtUser" Height="40" FontSize="14"
                                         Background="White" BorderBrush="#D1D5DB"
                                         Padding="15,10" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                            
                            <!-- Password -->
                            <StackPanel Margin="0,0,0,15">
                                <Label Content="Password" 
                                       Foreground="#1F2937" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <PasswordBox x:Name="txtPassword" Height="40" FontSize="14"
                                         Background="White" BorderBrush="#D1D5DB"
                                         Padding="15,10" VerticalContentAlignment="Center"
                                         PasswordChar="●">
                                    <PasswordBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </PasswordBox.Resources>
                                </PasswordBox>
                            </StackPanel>
                            
                            <!-- Database -->
                            <StackPanel>
                                <Label Content="Database" 
                                       Foreground="#1F2937" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="txtDatabase" Height="40" FontSize="14"
                                         Background="White" BorderBrush="#D1D5DB"
                                         Padding="15,10" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Stability Settings Section -->
                    <TextBlock Text="Stability Settings" 
                               Foreground="#2563EB" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,15"/>
                    
                    <Border Background="#F9FAFB" CornerRadius="8" Padding="20"
                            BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <!-- High Low Alarm -->
                            <StackPanel Margin="0,0,0,15">
                                <Label Content="High Low Alarm Level" 
                                       Foreground="#1F2937" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbHighLow" Height="40" FontSize="14"
                                          Background="White" BorderBrush="#D1D5DB"
                                          Padding="15,10">
                                    <ComboBoxItem Content="Disabled (0)"/>
                                    <ComboBoxItem Content="Enabled (1)"/>
                                    <ComboBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </StackPanel>
                            
                            <!-- Flood Rate -->
                            <StackPanel>
                                <Label Content="Flood Rate (Cu. M/S)" 
                                       Foreground="#1F2937" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                                <TextBox x:Name="txtFldRate" Height="40" FontSize="14"
                                         Background="White" BorderBrush="#D1D5DB"
                                         Padding="15,10" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,0,30,0">
                <Button Content="Exit" Width="80" Height="40"
                        Background="#6B7280" Foreground="White"
                        FontSize="14" FontWeight="SemiBold"
                        Margin="0,0,10,0" Cursor="Hand"
                        Click="btnExit_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Content="Test" Width="80" Height="40"
                        Background="#F59E0B" Foreground="White"
                        FontSize="14" FontWeight="SemiBold"
                        Margin="0,0,10,0" Cursor="Hand"
                        Click="btnTestConn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#D97706"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Content="Save" Width="80" Height="40"
                        Background="#2563EB" Foreground="White"
                        FontSize="14" FontWeight="SemiBold"
                        Margin="0,0,10,0" Cursor="Hand"
                        Click="btnSaveConfig_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Content="OK" Width="80" Height="40"
                        Background="#10B981" Foreground="White"
                        FontSize="14" FontWeight="SemiBold"
                        Cursor="Hand" Click="btnOk_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#059669"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
