<Window x:Class="WpfMvvmStability.Views.LoadingCondition"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading Condition" Height="430" Width="620"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Loaded="Window_Loaded" ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Background" Value="#1F48FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" BorderBrush="#DDE5FF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.18" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1F48FF" CornerRadius="12,12,0,0">
                <Grid>
                    <Label Name="lblConditionType" Content="Loading Condition"
                           Foreground="White" FontWeight="SemiBold" FontSize="18"
                           VerticalContentAlignment="Center" Padding="0"
                           VerticalAlignment="Center" Margin="24,0,60,0"/>
                    <Button Content="X" Width="34" Height="34" HorizontalAlignment="Right"
                            Margin="0,0,14,0" Background="Transparent" Foreground="White"
                            BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="btnExit_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="28,24,28,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F8FAFF" BorderBrush="#D8E2FF" BorderThickness="1" CornerRadius="8" Padding="10">
                    <Grid>
                        <ListBox Name="listBoxSavedCondition"
                                 BorderThickness="0" Background="White"
                                 FontSize="13" Padding="6"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        <Label Content="No Loading Condition Saved" Name="lblError"
                               Foreground="#EF4444" FontWeight="SemiBold"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Visibility="Hidden"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                    <Button Content="OK" Name="btnOK" Style="{StaticResource DialogButton}" Click="btnOK_Click"/>
                    <Button Content="Delete" Name="btnDelete" Style="{StaticResource DialogButton}"
                            Background="#EF4444" Click="btnDelete_Click"/>
                    <Button Content="Exit" Name="btnExit" Style="{StaticResource DialogButton}"
                            Background="#6B7280" Click="btnExit_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
