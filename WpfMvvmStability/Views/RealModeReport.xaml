<Page x:Class="WpfMvvmStability.Views.RealModeReport"
      x:Name="reportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:DV="clr-namespace:System.Windows.Controls.DataVisualization;assembly=System.Windows.Controls.DataVisualization.Toolkit"
      xmlns:DVC="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=System.Windows.Controls.DataVisualization.Toolkit"
      xmlns:chartPrimitive="clr-namespace:System.Windows.Controls.DataVisualization.Charting.Primitives;assembly=System.Windows.Controls.DataVisualization.Toolkit"
      mc:Ignorable="d" Title="RealModeReport" Background="#F5F7FA"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">
    <Page.Resources>
        <SolidColorBrush x:Key="PageBg" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#22C55E"/>
        <SolidColorBrush x:Key="AccentRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#F59E0B"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="RowAlt" Color="#F8FAFC"/>

        <!-- Watermark ImageBrush -->
        <ImageBrush x:Key="ReportWatermarkBrush" 
                    AlignmentX="Center" AlignmentY="Center" 
                    Stretch="Uniform" Opacity="0.1"
                    Viewport="0.2,0.2,0.6,0.6"
                    ViewportUnits="RelativeToBoundingBox">
            <ImageBrush.ImageSource>
                <BitmapImage UriSource="/Assets/Images/watermark_light.png"/>
            </ImageBrush.ImageSource>
        </ImageBrush>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="AccentBar" TargetType="Border">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SummaryValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="SummaryLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        </Style>

        <Style x:Key="BtnReport" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DGHeader" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Background" Value="#1E3A5F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="CenterCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="RowBackground" Value="{DynamicResource CardBg}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource RowAlt}"/>
            <Setter Property="RowHeight" Value="24"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="ColumnWidth" Value="*"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextBlock.HorizontalAlignment" Value="Center"/>
            <Setter Property="TextBlock.VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowAlt}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChartStyle1" TargetType="{x:Type DVC:Chart}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DVC:Chart}">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0"/>
                                    <RowDefinition Height="300"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentControl Content="{TemplateBinding Title}"
                                                FontFamily="Segoe UI"
                                                FontWeight="Bold"
                                                FontSize="14"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,8"/>
                                <Grid Margin="0,8,0,0"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      Grid.RowSpan="2">
                                    <chartPrimitive:EdgePanel x:Name="ChartArea"
                                                              Style="{TemplateBinding ChartAreaStyle}">
                                        <Grid Style="{TemplateBinding PlotAreaStyle}" Panel.ZIndex="-1"/>
                                        <Border BorderBrush="#B8C2CC" BorderThickness="1" Panel.ZIndex="10"/>
                                    </chartPrimitive:EdgePanel>
                                </Grid>
                                <ContentControl x:Name="Legend"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Top"
                                                Content="{TemplateBinding LegendTitle}"
                                                FontFamily="Segoe UI"
                                                FontWeight="Bold"
                                                FontSize="11"
                                                Foreground="{StaticResource TextPrimary}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource PageBg}">
        <!-- Report Page Watermark Container -->
        <Grid Background="{DynamicResource ReportWatermarkBrush}"/>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Stability Report"
                               Foreground="{DynamicResource TextPrimary}"
                               FontFamily="Segoe UI"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <Border x:Name="statusBorder" Background="#DCFCE7" CornerRadius="999" Padding="10,4" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtSummaryStatus" Text="INTACT" Foreground="#166534" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <Button Content="Generate Report" Name="btnGenerateReport" Click="btnGenerateReport_Click"
                        Style="{StaticResource BtnReport}" HorizontalAlignment="Right"/>
            </Grid>

            <ScrollViewer Grid.Row="1" Name="scrollViewer1" ScrollChanged="scrollViewer1_ScrollChanged" 
                          Background="Transparent" VerticalScrollBarVisibility="Auto">
                <Grid Name="grid1" Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TOP SUMMARY STRIP -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Report Summary" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,8"/>
                            <UniformGrid Columns="4">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="GMt" Style="{StaticResource SummaryLabel}"/>
                                    <TextBlock x:Name="txtSummaryGMT" Text="N/A" Style="{StaticResource SummaryValue}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Displacement" Style="{StaticResource SummaryLabel}"/>
                                    <TextBlock x:Name="txtSummaryDisplacement" Text="N/A" Style="{StaticResource SummaryValue}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Trim" Style="{StaticResource SummaryLabel}"/>
                                    <TextBlock x:Name="txtSummaryTrim" Text="N/A" Style="{StaticResource SummaryValue}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="List" Style="{StaticResource SummaryLabel}"/>
                                    <TextBlock x:Name="txtSummaryList" Text="N/A" Style="{StaticResource SummaryValue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Hidden controls preserved for functionality -->
                    <DatePicker Visibility="Collapsed" Name="datePickerTo" Grid.Row="0"/>
                    <ListBox Visibility="Collapsed" Name="listBoxDateList" Background="#FFDEDEDE" SelectionChanged="listBoxDateList_SelectionChanged" Grid.Row="0"/>
                    <Label Visibility="Hidden" Content="From" Name="lblFrom" Grid.Row="0"/>
                    <Label Visibility="Hidden" Content="To" Name="lblTo" Grid.Row="0"/>
                    <Button Visibility="Hidden" Content="Generate DateList" Name="btnGenerateDateList" Click="btnGenerateDateList_Click" Grid.Row="0"/>
                    <DatePicker Visibility="Hidden" Name="datePickerFrom" Grid.Row="0"/>

                    <!-- HYDROSTATICS -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#14B8A6"/>
                                <TextBlock Text="Hydrostatics" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <DataGrid Name="dgHydrostatics" 
                                      CanUserSortColumns="False" CanUserResizeRows="False" 
                                      VerticalScrollBarVisibility="Disabled" IsReadOnly="True"
                                      HorizontalScrollBarVisibility="Auto"
                                      HorizontalAlignment="Stretch">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Displacement (T)" Width="*" Binding="{Binding Displacement,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="LCB (m)" Width="*" Binding="{Binding LCB,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="TCB (m)" Width="*" Binding="{Binding TCB,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="VCB (m)" Width="*" Binding="{Binding VCB,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="KGF (m)" Width="*" Binding="{Binding [KG(Fluid)],StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="TCF (m)" Width="*" Binding="{Binding TCF,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="TCG (m)" Width="*" Binding="{Binding TCG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="LCG (m)" Width="*" Binding="{Binding LCG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="LCF (m)" Width="*" Binding="{Binding LCF,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="KMT (m)" Width="*" Binding="{Binding KMT,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="KML (m)" Width="*" Binding="{Binding KML,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="BMT (m)" Width="*" Binding="{Binding BMT,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="BML (m)" Width="*" Binding="{Binding BML,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="WPA (m2)" Width="*" Binding="{Binding WPA,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Buoyancy (T)" Width="*" Binding="{Binding Buoyancy,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Background="{StaticResource RowAlt}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" 
                                    CornerRadius="6" Padding="8" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Trim / Stability Snapshot" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,6"/>
                                    <DataGrid Name="dgHydrostatics2" 
                                              CanUserSortColumns="False" CanUserResizeRows="False" 
                                              VerticalScrollBarVisibility="Disabled" IsReadOnly="True"
                                              HorizontalScrollBarVisibility="Disabled">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Trim" Width="*" Binding="{Binding TRIM,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                            <DataGridTextColumn Header="List" Width="*" Binding="{Binding Heel,StringFormat=n2}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                            <DataGridTextColumn Header="GMT" Width="*" Binding="{Binding GMT,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                            <DataGridTextColumn Header="KG (m)" Width="*" Binding="{Binding [KG(Solid)],StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                            <DataGridTextColumn Header="KGF (m)" Width="*" Binding="{Binding [KG(Fluid)],StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                            <DataGridTextColumn Header="Roll Period" Width="*" Binding="{Binding Roll_Period,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- DRAFT MARKS -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#EC4899"/>
                                <TextBlock Text="Draft Marks (m)" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <DataGrid Name="dgDraft1" 
                                      CanUserSortColumns="False" CanUserResizeRows="False" 
                                      VerticalScrollBarVisibility="Disabled" IsReadOnly="True"
                                      HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="AP" Width="*" Binding="{Binding Draft_AP,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Aft Mark" Width="*" Binding="{Binding Draft_Aft_Mark,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Mid" Width="*" Binding="{Binding Draft_Mean,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Fwd Mark" Width="*" Binding="{Binding Draft_Fore_Mark,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="FP" Width="*" Binding="{Binding Draft_FP,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- MOULDED DRAFT -->
                    <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#8B5CF6"/>
                                <TextBlock Text="Moulded Draft (m)" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <DataGrid Name="dgMouldedDraft" 
                                      CanUserSortColumns="False" CanUserResizeRows="False" 
                                      VerticalScrollBarVisibility="Disabled" IsReadOnly="True"
                                      HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="AP" Width="*" Binding="{Binding Draft_AP,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Aft Mark" Width="*" Binding="{Binding Draft_Aft_Mark,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Mid" Width="*" Binding="{Binding Draft_Mean,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Fwd Mark" Width="*" Binding="{Binding Draft_Fore_Mark,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="FP" Width="*" Binding="{Binding Draft_FP,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- GZ AND HEELING ARMS -->
                    <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#6366F1"/>
                                <TextBlock Text="GZ and Heeling Arms" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <DataGrid Name="dgGZ" 
                                      CanUserSortColumns="False" CanUserResizeRows="False" 
                                      IsReadOnly="True" HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Heel (deg)" Width="*" Binding="{Binding HeelAngle,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="GZ (m)" Width="*" Binding="{Binding GZ,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Wind Heeling (m)" Width="*" Binding="{Binding WH,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Heavy Weights (m)" Width="*" Binding="{Binding HL,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Turning (m)" Width="*" Binding="{Binding HS,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Crowding (m)" Width="*" Binding="{Binding PC,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- LOADING SUMMARY -->
                    <Border Grid.Row="5" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#0EA5E9"/>
                                <TextBlock Text="Loading Summary" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <DataGrid Name="dgLoadingSummary" 
                                      CanUserSortColumns="False" CanUserResizeRows="False" 
                                      IsReadOnly="True" HorizontalScrollBarVisibility="Auto"
                                      MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tank Name" Width="1.5*" Binding="{Binding Tank_Name}" HeaderStyle="{StaticResource DGHeader}"/>
                                    <DataGridTextColumn Header="% Full" Width="*" Binding="{Binding Percent_Full,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Volume (m3)" Width="*" Binding="{Binding Volume,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="SG" Width="0.7*" Binding="{Binding SG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Weight (T)" Width="*" Binding="{Binding Weight,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="LCG (m)" Width="*" Binding="{Binding LCG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="TCG (m)" Width="*" Binding="{Binding TCG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="VCG (m)" Width="*" Binding="{Binding VCG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="FSM (T-m)" Width="*" Binding="{Binding FSM,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- DAMAGED TANKS -->
                    <Border x:Name="gbSoundingPer" Grid.Row="6" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#F97316"/>
                                <TextBlock Text="Damaged Tanks and Compartments" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <DataGrid Name="dgSoundingPer" 
                                      CanUserSortColumns="False" CanUserResizeRows="False" 
                                      IsReadOnly="True" HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Width="1.5*" Binding="{Binding Tank_Name}" HeaderStyle="{StaticResource DGHeader}"/>
                                    <DataGridTextColumn Header="% Full" Width="*" Binding="{Binding Percent_Full,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Volume (m3)" Width="*" Binding="{Binding CapacityMC,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Weight (T)" Width="*" Binding="{Binding CapacityTonnes,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="LCG (m)" Width="*" Binding="{Binding LCG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="TCG (m)" Width="*" Binding="{Binding TCG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="VCG (m)" Width="*" Binding="{Binding VCG,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border x:Name="groupDAMDISP" Margin="0,8,0,0" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Damaged Displacement" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                                    <DataGrid Name="Damaged_Displacement"
                                              CanUserSortColumns="False" CanUserResizeRows="False"
                                              IsReadOnly="True" HorizontalScrollBarVisibility="Auto"
                                              AutoGenerateColumns="True"
                                              HeadersVisibility="Column"
                                              MinHeight="80"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- IMMERSION PARTICULARS -->
                    <Border Grid.Row="7" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#A855F7"/>
                                <TextBlock Text="Immersion Particulars" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <DataGrid Name="dgDraft" 
                                      CanUserSortColumns="False" CanUserResizeRows="False" 
                                      IsReadOnly="True" HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Width="1.5*" Binding="{Binding openingName,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}"/>
                                    <DataGridTextColumn Header="Type" Width="*" Binding="{Binding openingNo,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="X (m)" Width="*" Binding="{Binding openingX,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Y (m)" Width="*" Binding="{Binding openingY,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Z (m)" Width="*" Binding="{Binding openingZ,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Flood Angle (deg)" Width="*" Binding="{Binding actualImAng,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- GZ CURVE - FULL WIDTH -->
                    <Border Grid.Row="8" Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#F59E0B"/>
                                <TextBlock Text="GZ Curve" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <Border Background="#F8FAFC" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Padding="4" MinHeight="220">
                                <Grid>
                                    <DVC:Chart Name="GzChart" Style="{StaticResource ChartStyle1}" Background="#F8FAFC" BorderBrush="{StaticResource BorderLight}" BorderThickness="0" Padding="5" MinHeight="220" FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}">
                                        <DVC:Chart.Series>
                                            <DVC:LineSeries Title="GZ" Name="GZSeries"
                                                    IndependentValueBinding="{Binding Path=Key}"
                                                    DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True">
                                                <DVC:LineSeries.DataPointStyle>
                                                    <Style TargetType="DVC:LineDataPoint">
                                                        <Setter Property="Background" Value="#2563EB"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="DVC:LineDataPoint">
                                                                    <Canvas/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </DVC:LineSeries.DataPointStyle>
                                            </DVC:LineSeries>
                                            <DVC:LineSeries Title="Wind Heeling" Name="WHSeries"
                                                    IndependentValueBinding="{Binding Path=Key}"
                                                    DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True">
                                                <DVC:LineSeries.DataPointStyle>
                                                    <Style TargetType="DVC:LineDataPoint">
                                                        <Setter Property="Background" Value="#16A34A"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="DVC:LineDataPoint">
                                                                    <Canvas/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </DVC:LineSeries.DataPointStyle>
                                            </DVC:LineSeries>
                                            <DVC:LineSeries Title="Heavy Weights" Name="HLSeries"
                                                    IndependentValueBinding="{Binding Path=Key}"
                                                    DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True">
                                                <DVC:LineSeries.DataPointStyle>
                                                    <Style TargetType="DVC:LineDataPoint">
                                                        <Setter Property="Background" Value="#F97316"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="DVC:LineDataPoint">
                                                                    <Canvas/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </DVC:LineSeries.DataPointStyle>
                                            </DVC:LineSeries>
                                            <DVC:LineSeries Title="Turning" Name="HSSeries"
                                                    IndependentValueBinding="{Binding Path=Key}"
                                                    DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True">
                                                <DVC:LineSeries.DataPointStyle>
                                                    <Style TargetType="DVC:LineDataPoint">
                                                        <Setter Property="Background" Value="#DC2626"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="DVC:LineDataPoint">
                                                                    <Canvas/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </DVC:LineSeries.DataPointStyle>
                                            </DVC:LineSeries>
                                            <DVC:LineSeries Title="Reference Curve" Name="PCSeries"
                                                    IndependentValueBinding="{Binding Path=Key}"
                                                    DependentValueBinding="{Binding Path=Value}" ItemsSource="{Binding}" IsSelectionEnabled="True">
                                                <DVC:LineSeries.DataPointStyle>
                                                    <Style TargetType="DVC:LineDataPoint">
                                                        <Setter Property="Background" Value="#9333EA"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="DVC:LineDataPoint">
                                                                    <Canvas/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </DVC:LineSeries.DataPointStyle>
                                        </DVC:LineSeries>
                                    </DVC:Chart.Series>
                                        <DVC:Chart.Axes>
                                            <DVC:LinearAxis Orientation="Y" Title="Righting Arm GZ (m)"/>
                                            <DVC:LinearAxis Orientation="X" Title="Heel Angle (deg)"/>
                                        </DVC:Chart.Axes>
                                    </DVC:Chart>
                                    <TextBlock x:Name="txtGzEmptyState"
                                               Text="No GZ data available"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- STABILITY CRITERIA -->
                    <Border Grid.Row="9" Style="{StaticResource CardStyle}" Margin="0,0,0,2">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource AccentBar}" Background="#10B981"/>
                                <TextBlock Text="NES 109 Stability Criteria" Style="{StaticResource SectionTitle}"/>
                            </StackPanel>
                            <DataGrid Name="dgStability" 
                                      CanUserSortColumns="False" CanUserResizeRows="False" 
                                      IsReadOnly="True" HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Criterion" Width="3*" Binding="{Binding Criterion}" HeaderStyle="{StaticResource DGHeader}"/>
                                    <DataGridTextColumn Header="Critical Value" Width="*" Binding="{Binding Critical_Value,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTextColumn Header="Actual Value" Width="*" Binding="{Binding Actual_Value,StringFormat=n3}" HeaderStyle="{StaticResource DGHeader}" ElementStyle="{StaticResource CenterCellStyle}"/>
                                    <DataGridTemplateColumn Header="Status" Width="*" HeaderStyle="{StaticResource DGHeader}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Center">
                                                     <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="OK">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="PASS">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="True">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="TRUE">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="NA">
                                                                    <Setter Property="Background" Value="#E5E7EB"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock HorizontalAlignment="Center" FontWeight="Bold" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="OK">
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="PASS">
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="True">
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="TRUE">
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="NA">
                                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding Status, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Hidden compatibility grid preserved for legacy code-behind -->
                    <DataGrid Name="test1"
                              Grid.Row="9"
                              Visibility="Collapsed"
                              AutoGenerateColumns="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"/>
                </Grid>
            </ScrollViewer>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="Transparent" Padding="0,6,0,0">
                <TextBlock Text="Confidential - Stability assessment for controlled circulation only" 
                           Foreground="{DynamicResource TextMuted}" FontFamily="Segoe UI" FontSize="10"/>
            </Border>
        </Grid>
    </Grid>
</Page>
